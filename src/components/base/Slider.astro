---
import styles from './Slider.module.css';

interface Slide {
  id: string;
  nombreEvento: string;
  fechaEvento?: string;
  descripcionEvento: string[];
  imagenPR: string;
  subtitle?: string;
  primaryButtonText?: string;
  ventaEntradas?: string;
  secondaryButtonText?: string;
}

interface Props {
  slides: Slide[];
  width?: string;
  height?: string;
  heightMobile?: string;
}

const { slides = [], width, height, heightMobile } = Astro.props;

const stylesVariables = {
  '--slider-width': width || '100%',
  '--slider-height': height || '500px',
  '--slider-height-mobile': heightMobile || '400px',
};

const base = import.meta.env.BASE_URL;
---

<div class={styles.sliderContainer} style={stylesVariables} id="mainSlider">
  <div class={styles.track} id="sliderTrack">
    {slides.map((slide, index) => (
      <div 
        class={`${styles.slide} ${index === 0 ? styles.active : ''}`} 
        data-index={index}
      >
        <img src={slide.imagenPR} alt={slide.nombreEvento} class={styles.image} loading={index === 0 ? 'eager' : 'lazy'} />
        <div class={styles.overlay} />
        <div class={styles.content}>
          <h2 class={styles.title}>{slide.nombreEvento}</h2>
          {slide.fechaEvento && (
              <div class={styles.date}>
                <i class="fas fa-calendar-alt" />
                {slide.fechaEvento}
              </div>
            )}
          {slide.descripcionEvento && <p class={styles.subtitle}>{slide.descripcionEvento[0]}</p>}
          <div class={styles.buttons}>
            {slide.primaryButtonText && (
              <a href={slide.ventaEntradas} class={`${styles.btn} ${styles.btnPrimary}`}>
                {slide.primaryButtonText}
              </a>
            )}

            {slide.secondaryButtonText && (
              <a href={`${base}eventos/${slide.id}`} class={`${styles.btn} ${styles.btnSecondary}`}>
                {slide.secondaryButtonText}
              </a>
            )}

          </div>
        </div>
      </div>
    ))}
  </div>

  <button class={`${styles.arrow} ${styles.prev}`} id="prevBtn" aria-label="Previous slide">
    <i class="fas fa-chevron-left" />
  </button>
  <button class={`${styles.arrow} ${styles.next}`} id="nextBtn" aria-label="Next slide">
    <i class="fas fa-chevron-right" />
  </button>

  <div class={styles.dots}>
    {slides.map((_, index) => (
      <span 
        class={`${styles.dot} ${index === 0 ? styles.dotActive : ''}`} 
        data-index={index} 
      />
    ))}
    {/* dot de pausa y play del slider */}
    <button id="pauseBtn" class={styles.controlBtn} data-index="pause" aria-label="Pause autoplay">
      <i class="fas fa-pause" />
    </button>
    <button id="playBtn" class={`${styles.controlBtn} ${styles.hidden}`} data-index="play" aria-label="Start autoplay">
      <i class="fas fa-play" />
    </button>
  </div>
</div>

<script>
  import styles from './Slider.module.css';

  function initSliders() {
    const sliders = document.querySelectorAll(`.${styles.sliderContainer}`);
    
    sliders.forEach(container => {
      const track = container.querySelector(`.${styles.track}`) as HTMLElement;
      const prevBtn = container.querySelector('#prevBtn');
      const nextBtn = container.querySelector('#nextBtn');
      const playBtn = container.querySelector(`[data-index="play"]`);
      const pauseBtn = container.querySelector(`[data-index="pause"]`);
      const dots = container.querySelectorAll(`.${styles.dot}`);
      const slides = container.querySelectorAll(`.${styles.slide}`);
      
      if (!track || !slides.length) return;

      let currentIndex = 0;
      const totalSlides = slides.length;
      let autoPlayInterval: number | undefined;

      function startAutoPlay() {
        stopAutoPlay();
        autoPlayInterval = window.setInterval(() => {
          updateSlider(currentIndex + 1);
        }, 5000);
      }

      function stopAutoPlay() {
        if (autoPlayInterval) {
          clearInterval(autoPlayInterval);
        }
      }

      function togglePlay(action: string) {
        if (action === 'play') {
          startAutoPlay();
          playBtn?.classList.add(styles.hidden);
          pauseBtn?.classList.remove(styles.hidden);
        } else {
          stopAutoPlay();
          playBtn?.classList.remove(styles.hidden);
          pauseBtn?.classList.add(styles.hidden);
        }
      }

      function updateSlider(index: number) {
        if (index < 0) index = totalSlides - 1;
        if (index >= totalSlides) index = 0;
        
        currentIndex = index;
        if (track) {
          track.style.transform = `translateX(-${currentIndex * 100}%)`;
        }
        
        slides.forEach((slide, i) => {
          slide.classList.toggle(styles.active, i === currentIndex);
        });

        dots.forEach((dot, i) => {
          dot.classList.toggle(styles.dotActive, i === currentIndex);
        });
      }

      prevBtn?.addEventListener('click', () => {
        updateSlider(currentIndex - 1);
        startAutoPlay();
      });

      nextBtn?.addEventListener('click', () => {
        updateSlider(currentIndex + 1);
        startAutoPlay();
      });

      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          updateSlider(i);
          startAutoPlay();
        });
      });

      playBtn?.addEventListener('click', () => togglePlay('play'));
      pauseBtn?.addEventListener('click', () => togglePlay('pause'));

      startAutoPlay();

      // Intersection Observer to stop autoplay when not visible
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) startAutoPlay();
          else stopAutoPlay();
        });
      }, { threshold: 0.1 });

      observer.observe(container);
    });
  }

  // Run on mount and transitions
  document.addEventListener('astro:page-load', initSliders);
</script>
