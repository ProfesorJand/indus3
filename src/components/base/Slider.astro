---
import styles from './Slider.module.css';

interface Slide {
  image: string;
  title: string;
  subtitle: string;
  date?: string;
  primaryButtonText?: string;
  primaryButtonLink?: string;
  secondaryButtonText?: string;
  secondaryButtonLink?: string;
}

interface Props {
  slides: Slide[];
  width?: string;
  height?: string;
  heightMobile?: string;
}

const { slides = [], width, height, heightMobile } = Astro.props;

const stylesVariables = {
  '--slider-width': width || '100%',
  '--slider-height': height || '500px',
  '--slider-height-mobile': heightMobile || '400px',
};
---

<div class={styles.sliderContainer} style={stylesVariables} id="mainSlider">
  <div class={styles.track} id="sliderTrack">
    {slides.map((slide, index) => (
      <div 
        class={`${styles.slide} ${index === 0 ? styles.active : ''}`} 
        data-index={index}
      >
        <img src={slide.image} alt={slide.title} class={styles.image} loading={index === 0 ? 'eager' : 'lazy'} />
        <div class={styles.overlay} />
        <div class={styles.content}>
          <h2 class={styles.title}>{slide.title}</h2>
          {slide.date && (
              <div class={styles.date}>
                <i class="fas fa-calendar-alt" />
                {slide.date}
              </div>
            )}
          <p class={styles.subtitle}>{slide.subtitle}</p>
          <div class={styles.buttons}>
            {slide.primaryButtonText && (
              <a href={slide.primaryButtonLink} class={`${styles.btn} ${styles.btnPrimary}`}>
                {slide.primaryButtonText}
              </a>
            )}
            {slide.secondaryButtonText && (
              <a href={slide.secondaryButtonLink} class={`${styles.btn} ${styles.btnSecondary}`}>
                {slide.secondaryButtonText}
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>

  <button class={`${styles.arrow} ${styles.prev}`} id="prevBtn" aria-label="Previous slide">
    <i class="fas fa-chevron-left" />
  </button>
  <button class={`${styles.arrow} ${styles.next}`} id="nextBtn" aria-label="Next slide">
    <i class="fas fa-chevron-right" />
  </button>

  <div class={styles.dots}>
    {slides.map((_, index) => (
      <span 
        class={`${styles.dot} ${index === 0 ? styles.dotActive : ''}`} 
        data-index={index} 
      />
    ))}
  </div>
</div>

<script>
  import styles from './Slider.module.css';
  function initSlider() {
    const container = document.getElementById('mainSlider');
    const track = document.getElementById('sliderTrack');
    const prevBtn = document.getElementById('prevBtn');
    const nextBtn = document.getElementById('nextBtn');
    
    if (!container || !track || !prevBtn || !nextBtn) return;

    const dots = container.querySelectorAll(`[class*="${styles.dot}"]`);
    const slides = track.querySelectorAll(`[class*="slide"]`);
    
    if (slides.length === 0) return;

    const activeSlideClass = slides[0].className.split(' ').find(c => c.includes('active')) || '';
    const activeDotClass = container.querySelector(`[class*="${styles.dotActive}"]`);
    let currentIndex = 0;
    const totalSlides = slides.length;
    let autoPlayInterval: number | undefined;

    function startAutoPlay() {
      stopAutoPlay();
      autoPlayInterval = window.setInterval(() => {
        updateSlider(currentIndex + 1);
      }, 5000);
    }

    function stopAutoPlay() {
      if (autoPlayInterval) {
        clearInterval(autoPlayInterval);
      }
    }

    function resetAutoPlay() {
      startAutoPlay();
    }

    function updateSlider(index: number) {
      if (index < 0) index = totalSlides - 1;
      if (index >= totalSlides) index = 0;
      
      currentIndex = index;
      if (track) track.style.transform = `translateX(-${currentIndex * 100}%)`;
      
      slides.forEach((slide, i) => {
        if (activeSlideClass) slide.classList.toggle(activeSlideClass, i === currentIndex);
      });

      dots.forEach((dot, i) => {
        dot.classList.toggle(styles.dotActive, i === currentIndex);
      });
    }

    prevBtn.addEventListener('click', () => {
      updateSlider(currentIndex - 1);
      resetAutoPlay();
    });

    nextBtn.addEventListener('click', () => {
      updateSlider(currentIndex + 1);
      resetAutoPlay();
    });

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => {
        updateSlider(i);
        resetAutoPlay();
      });
    });

    // Start initial auto-play
    startAutoPlay();
    
    // Cleanup if needed
    window.addEventListener('unload', stopAutoPlay);
  }

  // Run on mount
  initSlider();
  
  // Re-run on View Transitions
  document.addEventListener('astro:after-swap', initSlider);
</script>
