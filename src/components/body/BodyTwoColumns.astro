---
import styles from './BodyTwoColumns.module.css';
import Container from '@components/base/Container.astro';

interface Props {
  width?: string;
  height?: string;
  sidebarLeft?: boolean;
  padding?: string;
}

const { width, height, sidebarLeft = false, padding = '' } = Astro.props;
const classes = [styles.layout, sidebarLeft ? styles.flipped : ''].join(' ');
const styleContainer = {
  '--grid-columns': width || (sidebarLeft ? '300px 1fr' : '1fr 300px'),
  '--min-height': height || 'auto',
};

const styleSidebar ={
  '--min-height': height || 'auto',
}

const styleContent ={
  '--min-height': height || 'auto',
}
---

<Container padding={padding}>
  <div class={classes} style={styleContainer}>
    <main class={styles.content} style={styleSidebar}>
      <slot />
    </main>
    <aside class={styles.sidebar} style={styleContent}>
      <slot name="sidebar" />
    </aside>
  </div>
</Container>
