---
import styles from './HeaderSticky.module.css';
import Container from '@components/base/Container.astro';
import MobileMenu from './MobileMenu.jsx';
import ThemeToggle from '@components/base/ThemeToggle.astro';
import HorizontalLogo from '@components/logo/horizontal.astro';

const base = import.meta.env.BASE_URL;

const navigation = [
  { label: 'Inicio', href: `${base}` },
  { label: 'Servicios', href: `${base}servicios` },
  { label: 'Eventos', href: `${base}eventos` },
  { label: 'Guías', href: `${base}guias` },
  { label: 'Top Spotify', href: `${base}top-spotify` },
  { label: 'Contacto', href: `${base}contacto` },
];
---

<header class={styles.header} id="header-sticky" transition:persist>
  <Container className={styles.inner} padding="padding-0-32">
    <a href={base} class={styles.logo}><HorizontalLogo /></a>
    
    <nav class={styles.nav}>
      {navigation.map(item => (
        <a href={item.href} class={styles.navLink}>{item.label}</a>
      ))}
    </nav>

    <div class={styles.actions}>
      <ThemeToggle />
      <div class={styles.mobileActions}>
        <MobileMenu client:load items={navigation} />
      </div>
    </div>
  </Container>
</header>

<script>
  const header = document.getElementById('header-sticky');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 20) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }
  });
</script>
