---
import MainLayout from "@layouts/MainLayout.astro";
import HeaderSticky from "@components/headers/HeaderSticky.astro";
import FooterThreeCols from "@components/footers/FooterThreeCols.astro";
import Section from "@components/base/Section.astro";
import Container from "@components/base/Container.astro";
import BioForm from "@components/admin/BioForm.jsx";
---

<MainLayout title="Admin - Nueva Biografía">
  <HeaderSticky slot="header" />

  <main>
    <Section variant="hero">
      <Container>
        <div class="admin-header">
          <h1>Gestor de Biografías</h1>
          <p>Crea perfiles detallados para artistas, bandas o festivales.</p>
        </div>
        
        <BioForm client:load />
      </Container>
    </Section>
  </main>

  <FooterThreeCols slot="footer" />
</MainLayout>

<style>
  .admin-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .admin-header h1 {
    font-size: var(--font-size-4xl);
    margin-bottom: var(--space-4);
    background: linear-gradient(90deg, #fff 0%, var(--color-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .admin-header p {
    color: var(--color-text-light);
    font-size: var(--font-size-lg);
  }
</style>
