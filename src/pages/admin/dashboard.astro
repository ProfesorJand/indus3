---
import MainLayout from "@layouts/MainLayout.astro";
import SEO from "@components/seo/SEO.astro";
import DashboardComponent from "@components/admin/Dashboard.jsx";
import HeaderSticky from "@components/headers/HeaderSticky.astro";
import { getBiografias } from "@stores/biografias.js";
import {eventsData} from "@data/eventos.json";

// Fetch initial data
// const eventsData = await getEventos();
const biosData = await getBiografias();
const seoTitle = "Dashboard Administrativo | Indus3";
---

<MainLayout title={seoTitle}>
  <SEO
    slot="seo"
    title={seoTitle}
    description="Panel de control para la gestión de contenidos de Indus3."
  />
  <HeaderSticky slot="header" />
  <DashboardComponent
    client:load
    initialEvents={eventsData}
    initialBios={biosData}
  />
</MainLayout>

<style is:global>
  /* Reset some defaults for the dashboard to feel more app-like */
  body {
    overflow-x: hidden;
  }

  header,
  footer {
    display: none !important; /* Hide site-wide header/footer in dashboard */
  }
</style>
