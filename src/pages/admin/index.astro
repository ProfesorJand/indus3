---
import MainLayout from "@layouts/MainLayout.astro";
import SEO from "@components/seo/SEO.astro";

const seoTitle = "Admin Login - Indus3";
const seoDesc = "Acceso restringido para administradores de Indus3.";

// NOTA PARA EL USUARIO: Reemplaza esta URL con la ruta donde subas tus archivos PHP en GoDaddy
const BACKEND_URL = "https://api.indus3pro.com/auth"; 

const GOOGLE_CLIENT_ID = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID;
console.log({GOOGLE_CLIENT_ID})
---

<MainLayout title={seoTitle}>
  <SEO 
    slot="seo" 
    title={seoTitle} 
    description={seoDesc} 
  />

  <div class="admin-login-container">
    <div class="login-card">
      <div class="login-header">
        <img src="/indus3/indus3-logo.webp" alt="Indus3 Logo" class="login-logo" onerror="this.src='https://via.placeholder.com/150?text=Indus3'"/>
        <h1>Panel de Control</h1>
        <p id="step-description">Selecciona tu método de acceso para continuar.</p>
      </div>

      <!-- State: Selection -->
      <div id="step-choice" class="login-step active">
        <div class="google-btn-wrapper">
          <div id="google-login-btn"></div>
        </div>
        
        <div class="divider">
          <span>o accede con correo</span>
        </div>

        <button id="use-email-otp" class="btn btn-outline">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Código por Correo
        </button>
      </div>

      <!-- State: Email Input -->
      <div id="step-email" class="login-step">
        <div class="form-group">
          <label for="admin-email">Correo Electrónico</label>
          <input type="email" id="admin-email" placeholder="ejemplo@correo.com" />
        </div>
        <div class="btn-group">
          <button id="send-otp" class="btn btn-primary">Enviar Código</button>
          <button id="back-to-choice" class="btn btn-text">Volver</button>
        </div>
      </div>

      <!-- State: OTP Input -->
      <div id="step-otp" class="login-step">
        <p class="otp-notice">Hemos enviado un código de 6 dígitos a <br><strong id="display-email"></strong></p>
        <div class="otp-input-container">
          <input type="text" maxlength="1" class="otp-digit" />
          <input type="text" maxlength="1" class="otp-digit" />
          <input type="text" maxlength="1" class="otp-digit" />
          <input type="text" maxlength="1" class="otp-digit" />
          <input type="text" maxlength="1" class="otp-digit" />
          <input type="text" maxlength="1" class="otp-digit" />
        </div>
        <div class="btn-group">
          <button id="verify-otp" class="btn btn-primary">Verificar Acceso</button>
          <button id="resend-otp" class="btn btn-text">Reenviar código</button>
        </div>
      </div>

      <div id="login-feedback" class="feedback"></div>
    </div>
  </div>

  <style>
    .admin-login-container {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      padding: 2rem;
    }

    .login-card {
      width: 100%;
      max-width: 420px;
      background: rgba(255, 255, 255, 0.03);
      backdrop-filter: blur(12px);
      border: 1px border rgba(255, 255, 255, 0.1);
      border-radius: 24px;
      padding: 3rem 2rem;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
      text-align: center;
      color: white;
    }

    .login-header h1 {
      font-size: 1.8rem;
      margin: 1.5rem 0 0.5rem;
      font-weight: 700;
      letter-spacing: -0.025em;
    }

    .login-header p {
      color: #94a3b8;
      font-size: 0.95rem;
      margin-bottom: 2rem;
    }

    .login-logo {
      height: 60px;
      margin: 0 auto;
    }

    .login-step {
      display: none;
      flex-direction: column;
      gap: 1.5rem;
      animation: fadeIn 0.3s ease-out;
    }

    .login-step.active {
      display: flex;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .google-btn-wrapper {
      display: flex;
      justify-content: center;
      min-height: 40px;
    }

    .divider {
      display: flex;
      align-items: center;
      text-align: center;
      margin: 0.5rem 0;
    }

    .divider::before,
    .divider::after {
      content: '';
      flex: 1;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .divider span {
      padding: 0 1rem;
      font-size: 0.8rem;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .form-group {
      text-align: left;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .form-group label {
      font-size: 0.85rem;
      font-weight: 500;
      color: #cbd5e1;
    }

    .form-group input {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      padding: 0.8rem 1rem;
      color: white;
      font-size: 1rem;
      transition: all 0.2s;
    }

    .form-group input:focus {
      outline: none;
      border-color: #3b82f6;
      background: rgba(255, 255, 255, 0.08);
      box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
    }

    .otp-notice {
      font-size: 0.9rem;
      color: #94a3b8;
      line-height: 1.5;
    }

    .otp-input-container {
      display: flex;
      gap: 0.5rem;
      justify-content: center;
      margin: 1rem 0;
    }

    .otp-digit {
      width: 45px;
      height: 55px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 12px;
      text-align: center;
      font-size: 1.5rem;
      font-weight: 700;
      color: white;
      transition: all 0.2s;
    }

    .otp-digit:focus {
      outline: none;
      border-color: #3b82f6;
      background: rgba(255, 255, 255, 0.08);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.8rem 1.5rem;
      border-radius: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      border: none;
      font-size: 1rem;
    }

    .btn-primary {
      background: #3b82f6;
      color: white;
    }

    .btn-primary:hover {
      background: #2563eb;
      transform: translateY(-1px);
    }

    .btn-outline {
      background: transparent;
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: white;
    }

    .btn-outline:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: rgba(255, 255, 255, 0.4);
    }

    .btn-text {
      background: transparent;
      color: #94a3b8;
      font-size: 0.9rem;
    }

    .btn-text:hover {
      color: white;
    }

    .btn-group {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .feedback {
      margin-top: 1.5rem;
      font-size: 0.9rem;
      padding: 0.75rem;
      border-radius: 12px;
      display: none;
    }

    .feedback.error {
      background: rgba(239, 68, 68, 0.1);
      color: #f87171;
      display: block;
    }

    .feedback.success {
      background: rgba(34, 197, 94, 0.1);
      color: #4ade80;
      display: block;
    }
  </style>

  <script is:inline src="https://accounts.google.com/gsi/client" async defer></script>
  
  <script is:inline define:vars={{ BACKEND_URL, GOOGLE_CLIENT_ID }}>
    // UI Elements
    const steps = {
      choice: document.getElementById('step-choice'),
      email: document.getElementById('step-email'),
      otp: document.getElementById('step-otp')
    };
    const description = document.getElementById('step-description');
    const feedback = document.getElementById('login-feedback');
    const adminEmailInput = document.getElementById('admin-email');
    const displayEmail = document.getElementById('display-email');
    const otpDigits = document.querySelectorAll('.otp-digit');

    let currentEmail = "";

    function showStep(stepName) {
      Object.values(steps).forEach(s => s.classList.remove('active'));
      steps[stepName].classList.add('active');
      
      if (stepName === 'choice') {
        description.textContent = "Selecciona tu método de acceso para continuar.";
      } else if (stepName === 'email') {
        description.textContent = "Ingresa tu correo administrativo.";
      } else if (stepName === 'otp') {
        description.textContent = "Verificación de seguridad requerida.";
      }
      feedback.className = "feedback";
    }

    function showFeedback(message, type = 'error') {
      feedback.textContent = message;
      feedback.className = `feedback ${type}`;
    }

    // Google Auth Logic
    window.handleGoogleSignIn = async (response) => {
      try {
        const payload = JSON.parse(atob(response.credential.split('.')[1]));
        const email = payload.email;

        const url = `${BACKEND_URL}/auth-google.php`;

        const res = await fetch(url, {
          method: 'POST',
          headers: { 
            'Content-Type': 'application/json',
            'Authorization': `Bearer XW5V7VNGYUMILM1SJOAEKI8W48F1PVKW`
          },
          body: JSON.stringify({ email, token: response.credential })
        });

        // 🔥 SOLO UNA FORMA (JSON)
        const data = await res.json();

        console.log("DATA:", data);

        if (data.success) {
          showFeedback("Acceso concedido. Redirigiendo...", "success");
          setTimeout(() => window.location.href = "/admin/dashboard", 1500);
        } else {
          showFeedback(data.message || "Error desconocido.");
        }

      } catch (err) {
        console.error(err);
        showFeedback("Error al conectar con el servidor.");
      }
    };

    window.onload = () => {
      if (typeof google !== 'undefined') {
        google.accounts.id.initialize({
          client_id: GOOGLE_CLIENT_ID,
          callback: window.handleGoogleSignIn
        });
        google.accounts.id.renderButton(
          document.getElementById("google-login-btn"),
          { theme: "outline", size: "large", width: 350, text: "continue_with" }
        );
      }
    };

    // OTP Logic
    document.getElementById('use-email-otp').onclick = () => showStep('email');
    document.getElementById('back-to-choice').onclick = () => showStep('choice');

    document.getElementById('send-otp').onclick = async () => {
      const email = adminEmailInput.value;
      if (!email || !email.includes('@')) {
        return showFeedback("Por favor ingresa un correo válido.");
      }

      try {
        const res = await fetch(`${BACKEND_URL}/send-otp.php`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email })
        });

        const data = await res.json();
        if (data.success) {
          currentEmail = email;
          displayEmail.textContent = email;
          showStep('otp');
        } else {
          showFeedback(data.message || "Error al enviar el código.");
        }
      } catch (err) {
        console.log({err})
        showFeedback("Error de conexión.");
      }
    };

    document.getElementById('verify-otp').onclick = async () => {
      const otp = Array.from(otpDigits).map(i => i.value).join('');
      if (otp.length < 6) return showFeedback("Ingresa el código completo.");

      try {
        const res = await fetch(`${BACKEND_URL}/verify-otp.php`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: currentEmail, otp })
        });

        const data = await res.json();
        if (data.success) {
          showFeedback("Código verificado. Redirigiendo...", "success");
          setTimeout(() => window.location.href = "/admin/dashboard", 1500);
        } else {
          showFeedback(data.message || "Código incorrecto o expirado.");
        }
      } catch (err) {
        showFeedback("Error de conexión.");
      }
    };

    // Auto-focus OTP inputs
    otpDigits.forEach((input, idx) => {
      input.addEventListener('input', (e) => {
        if (e.target.value && idx < 5) otpDigits[idx+1].focus();
      });
      input.addEventListener('keydown', (e) => {
        if (e.key === 'Backspace' && !e.target.value && idx > 0) otpDigits[idx-1].focus();
      });
    });
  </script>
</MainLayout>
