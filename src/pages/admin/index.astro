---
import MainLayout from "@layouts/MainLayout.astro";
import SEO from "@components/seo/SEO.astro";
import LoginForm from "@components/admin/LoginForm.jsx";

const seoTitle = "Admin Login - Indus3";
const seoDesc = "Acceso restringido para administradores de Indus3.";

const BACKEND_URL = "https://api.indus3pro.com/auth"; 
const GOOGLE_CLIENT_ID = import.meta.env.PUBLIC_GOOGLE_CLIENT_ID;
---

<MainLayout title={seoTitle}>
  <SEO 
    slot="seo" 
    title={seoTitle} 
    description={seoDesc} 
  />

  <div class="admin-login-layout">
    <LoginForm 
      client:load 
      backendUrl={BACKEND_URL} 
      googleClientId={GOOGLE_CLIENT_ID} 
    />
  </div>

  <style>
    .admin-login-layout {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      padding: 2rem;
    }
  </style>
</MainLayout>
