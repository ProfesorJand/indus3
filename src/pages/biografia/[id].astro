---
import MainLayout from "@layouts/MainLayout.astro";
import HeaderSticky from "@components/headers/HeaderSticky.astro";
import FooterThreeCols from "@components/footers/FooterThreeCols.astro";
import Section from "@components/base/Section.astro";
import Container from "@components/base/Container.astro";
import biografias from "@data/biografias.json";
import SEO from "@components/seo/SEO.astro";
import BodyTwoColumns from "@components/body/BodyTwoColumns.astro";
import { redes } from "@stores/redes";
import SpotifyPlayer from "@components/base/SpotifyPlayer.astro";
import PersonSchema from "@components/seo/PersonSchema.astro";
import MusicGroupSchema from "@components/seo/MusicGroupSchema.astro";
import EventSchema from "@components/seo/EventSchema.astro";
import OrganizationSchema from "@components/seo/OrganizationSchema.astro";

export function getStaticPaths() {
  return biografias.map((bio) => ({
    params: { id: bio.id },
    props: { bio },
  }));
}

const { bio } = Astro.props;
const { pathname, href } = Astro.url;

const seoTitle = `${bio.name} - Biografía`;
const seoDesc = bio?.description || `Conoce la trayectoria de ${bio.name}`;
const bioType = bio.type?.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");

const base = import.meta.env.BASE_URL;
---

<MainLayout title={seoTitle}>
  <Fragment slot="seo">
    <SEO title={seoTitle} description={seoDesc} />
    {bioType === "artista" ? (
      <PersonSchema 
        name={bio.name}
        description={bio.description}
        image={bio.artistImg || bio.banner}
        url={href}
        genres={bio.genre}
        awards={bio.awards}
        birthPlace={bio.artistDetails?.[0]?.birthPlace}
        birthDate={bio.artistDetails?.[0]?.birthDate}
        height={bio.artistDetails?.[0]?.height}
      />
    ) : bioType === "organizacion" ? (
      <OrganizationSchema 
        name={bio.name}
        description={bio.description}
        image={bio.image || bio.banner || bio.imagenPR}
        url={href}
        foundingLocation={bio.foundingLocation || bio.lugarEvento}
        foundingDate={bio.foundingDate}
        awards={bio.awards}
      />
    ) : (bioType === "banda" || bioType === "duo") ? (
      <MusicGroupSchema 
        name={bio.name}
        description={bio.description}
        image={bio.image || bio.banner}
        url={href}
        genres={bio.genre}
        awards={bio.awards}
        foundingLocation={bio.foundingLocation}
        foundingDate={bio.foundingDate}
        members={bio.members}
      />
    ) : bioType === "evento" ? (
      <EventSchema 
        name={bio.name}
        description={bio.description}
        startDate={bio.details?.eventDate || bio.fechaEvento}
        url={href}
        locationName={bio.details?.location || bio.lugarEvento}
        image={bio.image || bio.banner || bio.imagenPR}
        organizerName={bio.details?.organizer}
      />
    ) : null}
  </Fragment>
  <HeaderSticky slot="header" />

  <main class="bio-page">

    <!-- 1. INTRODUCCIÓN: Artista y Descripción -->
    <Section variant="compact" className="intro-section">
      <Container variant="mid">
        <div style="display: flex; flex-direction: column; gap: var(--space-4);">
        {
          !bio.instagramReelVideo ? (
            <div class="intro-text">
            <div class="intro-text-header">
                <div class="mini-img-container">
                  <img src={bio.squareImg} alt={bio.name} class="artist-main-img" transition:name={`image-${bio.id}`} />
                </div>
                <div class="container-img-badge">
                  <h1 class="artist-name" transition:name={`title-${bio.id}`}>{bio.name}</h1>
                  <div class="bio-badge">{bio?.jobTitle?.toUpperCase()}</div>
                </div>
            </div>
            <div class="intro-text-history">
              <!-- <div class="intro-image-container">
                <img src={bio.artistImg} alt={bio.name} class="artist-main-img" transition:name={`image-${bio.id}`} />
                </div> -->
                <div class="bio-text-container">
                  <h2>Biografía</h2>
                  {
                    Array.isArray(bio.description) ? (
                      bio.description.map((parrafo) => (
                        <p class="artist-description">{parrafo}</p>
                      ))
                    ) : (
                      <p class="artist-description">{bio.description}</p>
                    )
                  }
                </div>
              </div>
            
          
          <div class="details-list">
            {bio.type?.toLowerCase() ==="artista" && bio.artistDetails?.map((detail) => (
              <div class="detail-card glass">
                {detail.realName && <h3>{detail.realName}</h3>}
                <ul>
                  {detail.birthPlace && <li><strong>Origen:</strong> {detail.birthPlace}</li>}
                  {detail.birthDate && <li><strong>Fecha de Nacimiento:</strong> {detail.birthDate}</li>}
                  {detail.height && <li><strong>Estatura:</strong> {detail.height}</li>}
                </ul>
              </div>
            ))}
          </div>
          </div>

            <div class="details-list">

              {
                bio.alternateName && (
                  <p class="info-text"><strong>Nombre Alternativo:</strong> {bio.alternateName}</p>
                )
              }
              {
                bio.foundingDate && (
                  <p class="info-text"><strong>Fecha de Fundación:</strong> {bio.foundingDate}</p>
                )
              }
              {
                bio.foundingLocation && (
                  <p class="info-text"><strong>Origen:</strong> {bio.foundingLocation}</p>
                )
              }
              {
                bio.members && (
                  <p class="info-text"><strong>Integrantes:</strong> {bio.members.map(({name, rol}) => `${name} (${rol})`).join(", ")}</p>
                )
              }
              {
                bio.awards && bio.awards.length > 0 && (
                  <p class="info-text"><strong>Premios:</strong> {bio.awards.join(", ")}</p>
                )
              }
          
          {bio.genre && bio.genre.length > 0 && (
            <div class="genre-container">
              <strong>Género:</strong> {bio.genre.join(", ")}
            </div>
          )}
            </div>

          ) : (

          <BodyTwoColumns flexDirection="column" sidebarLeft={true} gap="var(--space-4)">
            <div slot="sidebar">
              <div class="video-wrapper shadow-xl" slot="sidebar">
                <video controls loop playsinline class="my-reel">
                  <source src={`${base}${bio.instagramReelVideo}`} type="video/mp4" />
                  Tu navegador no soporta videos.
                </video>
              </div>
              <p class="see-more" style="color: var(--color-primary);">
                <a href={redes.instagram} target="_blank">Ver más contenido -> instagram/@indus3pro</a>
              </p>
            </div>
            <div class="intro-text">
              <div class="intro-text-header">
                  <div class="mini-img-container">
                    <img src={bio.squareImg} alt={bio.name} class="artist-main-img" transition:name={`image-${bio.id}`} />
                  </div>
                <div class="container-img-badge">
                  <h1 class="artist-name" transition:name={`title-${bio.id}`}>{bio.name}</h1>
                  <div class="bio-badge">{bio?.jobTitle?.toUpperCase()}</div>
                </div>
              </div>
              <div class="intro-text-history">
                <!-- <div class="intro-image-container">
                  <img src={bio.artistImg} alt={bio.name} class="artist-main-img" transition:name={`image-${bio.id}`} />
                  </div> -->
                  <div class="bio-text-container">
                    <h2>Biografía</h2>
                    {
                      Array.isArray(bio.description) ? (
                        bio.description.map((parrafo) => (
                          <p class="artist-description">{parrafo}</p>
                        ))
                      ) : (
                        <p class="artist-description">{bio.description}</p>
                      )
                    }
                  </div>
                </div>
              
            
            <div class="details-list">
              {bio.type?.toLowerCase() ==="artista" && bio.artistDetails?.map((detail) => (
                <div class="detail-card glass">
                  {detail.realName && <h3>{detail.realName}</h3>}
                  <ul>
                    {detail.birthPlace && <li><strong>Origen:</strong> {detail.birthPlace}</li>}
                    {detail.birthDate && <li><strong>Fecha de Nacimiento:</strong> {detail.birthDate}</li>}
                    {detail.height && <li><strong>Estatura:</strong> {detail.height}</li>}
                  </ul>
                </div>
              ))}
            </div>
            </div>
              <div class="details-list">
                {
                  bio.alternateName && (
                    <p class="info-text"><strong>Nombre Alternativo:</strong> {bio.alternateName}</p>
                  )
                }
                {
                  bio.foundingDate && (
                    <p class="info-text"><strong>Fecha de Fundación:</strong> {bio.foundingDate}</p>
                  )
                }
                {
                  bio.foundingLocation && (
                    <p class="info-text"><strong>Origen:</strong> {bio.foundingLocation}</p>
                  )
                }
                {
                  bio.members && (
                    <p class="info-text"><strong>Integrantes:</strong> {bio.members.map(({name, rol}) => `${name} (${rol})`).join(", ")}</p>
                  )
                }
                {
                  bio.awards && bio.awards.length > 0 && (
                    <p class="info-text"><strong>Premios:</strong> {bio.awards.join(", ")}</p>
                  )
                }
            
            {bio.genre && bio.genre.length > 0 && (
              <div class="genre-container">
                <strong>Género:</strong> {bio.genre.join(", ")}
              </div>
            )}
              </div>
          </BodyTwoColumns>
          )

        }
       <!-- Info De la Biografia -->
        <div style="display: flex; flex-direction: column; gap: var(--space-4);">
        <!-- 2. MÚSICA: Éxitos Destacados -->
        <h2 class="section-title">5 Canciones más famosas de {bio.name}</h2>
        <ol>
          <li>
            Se Acabó
          </li>
          <li>
            Sin Miedo 2020
          </li>
          <li>
            Como Yo (feat. Silvestre Dangong)
          </li>
          <li>
            Mis Ilusiones
          </li>
          <li>
            Donde Andabas Tú
          </li>
        </ol>
        {bio.urlSpotify && (
              <div class="music-section glass">
                <div class="music-container">
                  <SpotifyPlayer url={bio.urlSpotify} height={"100%"} title={`Spotify de ${bio.name}`} />
                </div>
              </div>
        )}
        </div>
        </div>
      </Container>
    </Section>
  </main>

  <FooterThreeCols slot="footer" />
</MainLayout>

<style>
  .bio-text-container{
    display: flex;
    flex-direction: column;
    gap:var(--space-4)
  }
  .artist-description {
    font-size: var(--font-size-base);
    line-height: 1.6;
    color: var(--color-text-light);
    margin: 0;
  }
  .container-img-badge{
    display: flex;
    flex-direction: column;
    align-items: center;
    
  }
  .bio-page {
    overflow-x: hidden;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: var(--space-12);
    align-items: center;
    padding-top: var(--space-8);
  }

  .bio-badge {
    background: var(--color-primary);
    color: white;
    display: inline-block;
    padding: 4px 12px;
    border-radius: var(--border-radius-full);
    font-size: var(--font-size-xs);
    font-weight: 800;
    letter-spacing: 1px;
    width: fit-content;
  }

  .genre{
    background: var(--color-secondary);
  }

  .artist-name {
    font-weight: 900;
    line-height: 1.1;
  }
  
  .intro-text-header{
    display: flex;
    align-items: center;
    gap: var(--space-4);
    flex-direction: row;
  }

  .intro-text-history{
    display: flex;
    gap: var(--space-4);
    align-items: flex-start;
  }
  
  .mini-img-container{
    min-width: 100px;
    min-height: 100px;
    max-width: 140px;
    aspect-ratio:1/1;
    border-radius: 50%;
    overflow: hidden;
    border: 5px solid rgba(255,255,255,0.1);
    display:flex;
    flex-direction: column;
    justify-content: center;
    
  }
  .artist-main-img{
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .artist-main-img {
    width: 100%;
    border-radius: var(--border-radius-2xl);
    box-shadow: var(--shadow-2xl);
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .details-list {
    display: flex;
    flex-wrap: wrap;
    flex-direction:column;
    gap: var(--space-6);
  }

  .detail-card {
    padding: var(--space-6);
    flex: 1 1 250px;
    border: 1px solid rgba(255,255,255,0.05);
  }

  .detail-card h3 {
    font-size: var(--font-size-xl);
    margin-bottom: var(--space-3);
    color: var(--color-primary);
  }

  .detail-card ul {
    list-style: none;
    padding: 0;
  }

  .detail-card li {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    margin-bottom: 4px;
  }

  .glass {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    border-radius: var(--border-radius-xl);
  }

  .music-section {
    height: 100%;
    padding: var(--space-4);
    border: 1px solid rgba(255,255,255,0.1);
    display: flex;
    flex-direction: column;
  }

  .section-title {
    font-size: var(--font-size-2xl);
    font-weight: 800;
  }

  .section-title.centered {
    text-align: center;
    margin-bottom: var(--space-4);
  }

  .music-container{
    display: flex;
    position:relative;
    height: 550px;
    width:100%;
  }
  .awards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(50%, 1fr));
    gap: var(--space-6);
  }

  .award-item {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    padding: var(--space-8);
    transition: transform 0.3s ease;
  }

  .award-item:hover {
    transform: translateY(-5px);
    background: rgba(255,255,255,0.06);
  }

  .icon-box {
    background: rgba(255, 255, 255, 0.05);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .icon-box i {
    color: var(--color-primary);
    font-size: 1.25rem;
  }

  .video-wrapper {
    max-width: 450px;
    margin: 0 auto;
    border-radius: 16px;
    overflow: hidden;
    background: #000;
    line-height: 0;
    box-shadow: 0 20px 50px rgba(0,0,0,0.5);
  }

  .my-reel {
    width: 100%;
    height: auto;
  }

  .see-more {
    text-align: center;
    font-size: var(--font-size-sm);
    margin: var(--space-2);
  }

  /* .background{
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: -1;
    height: 100vh;
    width: 100%;
  }

  .background-image{
    width: 100%;
    height: 100%;
    object-fit: cover;
  } */

  @media (max-width: 1024px) {
    .intro-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .intro-text {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .details-list {
      justify-content: center;
    }
    .intro-image-container {
      
      max-width: 500px;
      margin: 0 auto;
    }
  }
</style>
