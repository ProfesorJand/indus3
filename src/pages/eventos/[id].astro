---
import MainLayout from "@layouts/MainLayout.astro";
import SEO from "@components/seo/SEO.astro";
import HeaderSticky from "@components/headers/HeaderSticky.astro";
import FooterThreeCols from "@components/footers/FooterThreeCols.astro";
import Section from "@components/base/Section.astro";
import Container from "@components/base/Container.astro";
import BodyGrid from "@components/body/BodyGrid.astro";
import { getEventos } from "@stores/eventos";
import { getBiografias } from "@stores/biografias";
import SpotifyPlayer from "@components/base/SpotifyPlayer.astro";
import EventSchema from "@components/seo/EventSchema.astro";
import BodyTwoColumns from "@components/body/BodyTwoColumns.astro";


export async function getStaticPaths() {
  const eventsData = await getEventos();
  console.log({eventsData})
  return eventsData.map((event) => ({
    params: { id: event.id.toString() },
    props: { event },
  }));
}

const { event } = Astro.props;
console.log({preguntas: event.preguntas})
const seoTitle = `${event.nombreEvento} | Indus3`;
const seoDesc = event?.descripcionEvento || "Mini Descripcion";
const biografiasArtistas = await getBiografias();
const datosArtistas = biografiasArtistas.filter((artista) => event?.artistas?.includes(artista.id));

const base = import.meta.env.BASE_URL;
---

<MainLayout title={seoTitle}>
  <Fragment slot="seo">
    <SEO title={seoTitle} description={seoDesc} />
    <EventSchema 
      name={event.nombreEvento}
      description={event.descripcionEvento}
      startDate={event.fechaEvento}
      locationName={event.lugarEvento}
      image={event.imagenPR || event.imagenBanner}
      offersUrl={event.ventaEntradas}
      performers={datosArtistas.map(a => ({ name: a.name, type: a.type === "Grupo Musical" ? "MusicGroup" : "Person" }))}
    />
  </Fragment>
  
  <HeaderSticky slot="header" />

  <main>
    <!-- Hero Banner -->
     <!-- Photo Banner / Middle Section -->
    {event.imagenPR && (
      <div class="pr-banner">
        <img src={event.imagenPR} alt="Prense/PR Evento" class="hero-img"/>
        <div class="pr-overlay">
          <div class="pr-content">
            <h1 class="pr-title">{event.nombreEvento}</h1>
            {/* <div class="info-item info-place glass ">
              <div class="info-icon"><i class="fas fa-map-marker-alt"></i></div>
              <div>
                <span>Lugar</span>
                <strong>{event.lugarEvento}</strong>
              </div>
            </div> */}
          </div>
          {/* <div class="info-bar glass">
            <div class="info-grid">
              <div class="info-item">
              </div>
              <div class="info-item">
                <div class="info-icon"><i class="fas fa-calendar-alt"></i></div>
                <div>
                  <span>Fecha</span>
                  <strong>{event.fechaEvento}</strong>
                </div>
              </div>
              <div class="info-item">
                <div class="info-icon"><i class="fas fa-door-open"></i></div>
                <div>
                  <span>Apertura</span>
                  <strong>{event.aperturaPuertas}</strong>
                </div>
              </div>
              <div class="info-item">
                <div class="info-icon"><i class="fas fa-clock"></i></div>
                <div>
                  <span>Show</span>
                  <strong>{event.comienzoShow}</strong>
                </div>
              </div>
              <div class="info-item hide-mobile">
                <div class="info-icon"><i class="fas fa-users"></i></div>
                <div>
                  <span>Edad</span>
                  <strong>{event.restriccionesEdad}</strong>
                </div>
              </div>
              <div class="info-action">
                <a href={event.ventaEntradas} target="_blank" class="btn-tickets pulse">
                <i class="fas fa-ticket-alt"></i> Comprar Entradas 
                </a>
              </div>
            </div>
          </div> */}
        </div>
      </div>
    )}

    
    <!-- Main Content -->
    <Section>
      <Container variant="mid" flexDirection="column">
        <div class="container"> 
           {
            event.preguntas.map((pregunta) => (
              <div class="reveal-up question-block">
                <h2 class="section-title">{pregunta.pregunta}</h2>
                <div class="answer-wrapper">
                  {
                    // Dividimos la respuesta por cada salto de línea (\n)
                    pregunta.respuesta.split('\n').map((linea) => (
                      linea.trim() && <p class="answer-p">{linea}</p> 
                    ))
                  }
                </div>
              </div>
            ))
           }

        <div class="content-left">
        
        {datosArtistas && datosArtistas.length > 0 && (
          <div class="artists-section">
        <h2 class="section-title">{datosArtistas.length === 1 ? "Artista " : "Artistas "} que se presentan en {event.nombreEvento}</h2>
        {datosArtistas.map((artista) => (
          <div class="artist-card glass reveal-up">
            {/* <div class="artist-image-wrap">
              <img src={artista.artistImg} alt={artista.name} class="artist-img" />
              <div class="artist-badge">{artista.paisNacimiento}</div>
              </div> */}
            <div class="artist-info">
                {/* <h3>{artista.name}</h3>
                <p>{artista.description}</p> */}
                
                {artista.urlSpotify && (
                  <div class="spotify-mini-list">
                    <span class="spotify-label"><i class="fab fa-spotify"></i> Top Canciones de {artista.name}</span>
                    <SpotifyPlayer url={artista.urlSpotify} height={400} title={`Spotify de ${artista.name}`} />
                  </div>
                )}

                {artista.id && (
                  <a href={`${base}biografia/${artista.id}`} class="btn-bio">Conocer Biografia de {artista.name} <i class="fas fa-arrow-right"></i></a>
                )}
            </div>
          </div>
        ))}
      </div>
    )}
          </div>
        </div>      
      </Container>
    </Section>

    

    

    <!-- Sponsors -->
    {event.patrocinadores && event.patrocinadores.length > 0 && (
      <Section variant="alt">
        <Container>
          <h3 class="section-title" style="text-align: center; margin-bottom: 3rem;">Nuestros Aliados</h3>
          <div class="sponsors-grid">
             {event.patrocinadores.map(imgUrl => (
               <div class="sponsor-card">
                 <img src={imgUrl} alt="Patrocinador" class="sponsor-logo" />
               </div>
             ))}
          </div>
        </Container>
      </Section>
    )}
  </main>

  <FooterThreeCols slot="footer" />
</MainLayout>

<style>

  .answer-wrapper{
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .container{
    display: flex;
    flex-direction: column;
    gap:var(--space-4)
  }
  main {
    background-color: var(--color-bg);
    color: var(--color-text);
  }

  /* Hero Section */
  .event-hero {
    position: relative;
    height: 80vh;
    min-height: 600px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }
  .hero-img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.05);
    animation: slowZoom 20s infinite alternate;
  }
  @keyframes slowZoom {
    from { transform: scale(1); }
    to { transform: scale(1.1); }
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(0deg, var(--color-bg) 0%, rgba(0,0,0,0.4) 50%, transparent 100%);
  }
  .hero-content {
    position: relative;
    z-index: 2;
    padding-bottom: 6rem;
  }
  .hero-text-wrap {
    max-width: 800px;
  }
  .event-badge {
    background: var(--color-primary);
    color: white;
    display: inline-block;
    padding: 0.6rem 1.2rem;
    border-radius: var(--border-radius-full);
    font-size: 0.75rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 15px rgba(var(--color-primary-rgb), 0.4);
  }
  .event-title {
    font-size: clamp(3rem, 10vw, 6rem);
    font-weight: 900;
    line-height: 0.9;
    margin-bottom: 1.5rem;
    color: white;
    text-shadow: 0 10px 30px rgba(0,0,0,0.5);
  }
  .hero-meta {
    display: flex;
    gap: 2rem;
    color: rgba(255,255,255,0.9);
    font-size: 1.2rem;
    font-weight: 500;
  }
  .meta-item i {
    color: var(--color-primary);
    margin-right: 0.5rem;
  }

  /* Glassmorphism Utility */
  .glass {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
  }

  /* Info Bar */
  .info-bar-container {
    margin-top: -4rem;
    position: relative;
    z-index: 10;
  }
  .info-bar {
    padding: 2rem;
    border-radius: var(--border-radius-2xl, 2rem);
  }

  .info-place {
    padding: 1rem;
    border-radius: var(--border-radius-2xl, 2rem);
    width: fit-content;
  }
  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    align-items: center;
    gap: 2rem;
  }
  .info-item {
    display: flex;
    align-items: center;
    gap: 1.2rem;
  }
  .info-icon {
    width: 48px;
    height: 48px;
    background: var(--color-primary);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-white);
    font-size: 1.25rem;
  }
  .info-item span {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-bottom: 0.2rem;
  }
  .info-item strong {
    font-size: 1.1rem;
    color: white;
    font-weight: 700;
  }
  .btn-tickets {
    background: var(--color-primary);
    color: white;
    padding: 1.2rem 2.5rem;
    border-radius: 1rem;
    font-weight: 800;
    text-decoration: none;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-size: 0.9rem;
  }
  .btn-tickets:hover {
    transform: translateY(-5px) scale(1.02);
    box-shadow: 0 15px 30px rgba(var(--color-primary-rgb, 59, 130, 246), 0.4);
    filter: brightness(1.1);
  }
  .pulse {
    animation: cardPulse 3s infinite;
  }
  @keyframes cardPulse {
    0% { box-shadow: 0 0 0 0 rgba(var(--color-primary-rgb, 59, 130, 246), 0.4); }
    70% { box-shadow: 0 0 0 15px rgba(var(--color-primary-rgb, 59, 130, 246), 0); }
    100% { box-shadow: 0 0 0 0 rgba(var(--color-primary-rgb, 59, 130, 246), 0); }
  }

  /* Content Sections */
  .section-title {
    font-size: var(--font-size-3xl);
    font-weight: 800;
    color: var(--color-primary);
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .section-title::after {
    content: "";
    height: 2px;
    flex-grow: 1;
    background: linear-gradient(90deg, var(--color-primary), transparent);
    opacity: 0.3;
  }
  .description-wrap {
    margin-bottom: 3rem;
  }
  .description {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
  }

  /* Logistics Card */
  .logistics-card {
    padding: 2.5rem;
    border-radius: 1.5rem;
    margin-bottom: 3rem;
  }
  .logistics-card h3 {
    margin-bottom: 1.5rem;
    font-size: 1.5rem;
    color: white;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .logistics-card h3 i { color: var(--color-primary); }
  .logistics-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 2rem;
  }
  .tag {
    background: rgba(255,255,255,0.05);
    padding: 0.5rem 1rem;
    border-radius: var(--border-radius-full);
    font-size: 0.85rem;
    color: var(--color-primary-light, #93c5fd);
    border: 1px solid rgba(var(--color-primary-rgb), 0.2);
  }

  /* Flyer Section */
  .flyer-section { margin-top: 3rem; }
  .flyer-container {
    position: relative;
    border-radius: 1.5rem;
    overflow: hidden;
    max-width: 500px;
    group: hover;
  }
  .flyer-img {
    width: 100%;
    transition: transform 0.5s ease;
  }
  .flyer-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }
  .flyer-container:hover .flyer-overlay { opacity: 1; }
  .flyer-container:hover .flyer-img { transform: scale(1.05); }
  .btn-zoom {
    width: 60px;
    height: 60px;
    background: white;
    color: black;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    text-decoration: none;
    transform: translateY(20px);
    transition: all 0.3s ease;
  }
  .flyer-container:hover .btn-zoom { transform: translateY(0); }

  /* Artist Card */
  .artist-card {
    border-radius: 1.5rem;
    overflow: hidden;
    margin-bottom: 2rem;
  }
  .artist-image-wrap {
    position: relative;
    height: 350px;
    width: 250px
  }
  .artist-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .artist-badge {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: var(--color-primary);
    color: white;
    padding: 0.4rem 1rem;
    border-radius: var(--border-radius-full);
    font-size: 0.75rem;
    font-weight: 700;
  }
  .artist-info {
    padding: 2rem;
  }
  .artist-info h3 { 
    margin-bottom: 1rem; 
    font-size: 1.8rem;
    color: white;
  }
  .artist-info p {
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }
  .spotify-mini-list {
    margin-top: 1.5rem;
    background: rgba(0,0,0,0.2);
    padding: 1.5rem;
    border-radius: 1.25rem;
  }
  .spotify-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 700;
    color: #1DB954; /* Spotify Green */
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .btn-bio {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1rem;
    color: var(--color-primary);
    text-decoration: none;
    font-weight: 700;
    transition: all 0.2s ease;
  }
  .btn-bio:hover { gap: 0.8rem; color: var(--color-primary-light); }

  /* Curiosities List */
  .curiosities-card { padding: 2.5rem; border-radius: 1.5rem; }
  .curiosities-list {
    list-style: none;
    padding: 0;
  }
  .curiosities-list li {
    padding: 0.8rem 0;
    padding-left: 2rem;
    position: relative;
    color: var(--color-text-light);
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .curiosities-list li:last-child { border: none; }
  .curiosities-list li::before {
    content: "\f0eb";
    font-family: "Font Awesome 6 Free";
    font-weight: 900;
    color: var(--color-accent);
    position: absolute;
    left: 0;
    font-size: 1rem;
  }

  /* PR Banner */
  .pr-banner {
    position: relative;
    height: 60vh;
    min-height: 50vh;
    overflow: hidden;
    margin: var(--space-4) 0;
  }
  .pr-banner img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .pr-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: space-around;
    flex
  }
  .pr-content{
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .pr-title {
    font-size: clamp(2rem, 5vw, 4rem);
    color: white;
    font-weight: 900;
    max-width: 800px;
    line-height: 1.1;
        text-shadow: -1px -1px 0 #000, 1px -1px 0 #000, -1px 1px 0 #000, 3px 3px 0 #000;
  }

  /* Sponsors */
  .sponsors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 3rem;
  }
  .sponsor-card {
    height: 120px;
    background: white;
    padding: 1.5rem;
    border-radius: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    filter: grayscale(1) opacity(0.6);
  }
  .sponsor-card:hover {
    filter: grayscale(0) opacity(1);
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.15);
  }
  .sponsor-logo {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  /* Reveal Animations */
  .reveal-up {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s cubic-bezier(0.2, 0, 0, 1) forwards;
  }
  /* In a real project you'd use IntersectionObserver, 
     here we use a simple animation trigger or just show them for now 
     to ensure they're visible if no JS is running. */
  .reveal-up { opacity: 1; transform: translateY(0); }

  /* Mobile Adjustments */
  @media (max-width: 768px) {
    .event-hero { height: 60vh; }
    .hero-meta { flex-direction: column; gap: 0.5rem; }
    .info-bar-container { margin-top: -2rem; padding: 0 1rem; }
    .info-grid { grid-template-columns: 1fr; gap: 1rem; }
    .hide-mobile { display: none; }
    .btn-tickets { width: 100%; }
    .logistics-card { padding: 1.5rem; }
  }
</style>

