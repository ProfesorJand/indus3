---
import MainLayout from "@layouts/MainLayout.astro";
import SEO from "@components/seo/SEO.astro";
import HeaderSticky from "@components/headers/HeaderSticky.astro";
import FooterThreeCols from "@components/footers/FooterThreeCols.astro";
import Section from "@components/base/Section.astro";
import Container from "@components/base/Container.astro";
import BodyGrid from "@components/body/BodyGrid.astro";
import fs from "node:fs";
import path from "node:path";
import LogoCard from "@components/logo/LogoCard.astro";

//import { getEventos } from "src/scripts/eventos.js";
import eventsData from "@data/eventos.json";


//const eventsData = await getEventos();
console.log(eventsData);

const seoTitle = "Eventos | Indus3";
const seoDesc =
  "Próximos eventos, conciertos y festivales producidos por Indus3.";
const projectRoot = process.cwd();
const clientesDir = path.resolve(projectRoot, "public/eventos-pasados");
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

let files: string[] = [];
try {
  files = fs.readdirSync(clientesDir);
  if (files.length === 0)
    console.warn("Warning: No files found in", clientesDir);
} catch (error) {
  console.error("Error reading clients directory 3:", error);
}
const eventosPasados = files
  .filter((file) => /\.(webp|png|jpg|jpeg|svg)$/i.test(file))
  .map((file) => {
    const nameWithoutExt = file.replace(/\.[^/.]+$/, "");
    // Remove "Logo-" prefix and replace hyphens with spaces
    const title = nameWithoutExt.replace(/^Logo-/i, "").replace(/-/g, " ");

    return {
      image: `${baseUrl}/eventos-pasados/${file}`,
      title: title,
      link: "/#",
    };
  });

const base = import.meta.env.BASE_URL;
---

<MainLayout title={seoTitle}>
  <SEO slot="seo" title={seoTitle} description={seoDesc} />

  <HeaderSticky slot="header" />

  <Section variant="hero">
    <Container variant="mid" flexDirection="column">
      <h1
        style="text-align: center; font-size: var(--font-size-4xl); margin-bottom: var(--space-4);"
      >
        Cartelera de Eventos
      </h1>
      <p
        style="text-align: center; color: var(--color-text-light); max-width: 600px; margin: 0 auto;margin-bottom: var(--space-4);"
      >
        Descubre las próximas experiencias que tenemos preparadas para ti.
      </p>

      {
        eventsData.length > 0 ? (
          <BodyGrid
            columns={eventsData.length > 3 ? 3 : eventsData.length}
            justifyContent="center"
          >
            {eventsData.map((event) => (
              <a href={`${base}eventos/${event.id}`} class="event-card">
                <div class="image-wrapper">
                  <img src={event.imagenPR} alt={event.nombreEvento} />
                  <div class="date-badge">{event.fechaEvento}</div>
                </div>
                <div class="content">
                  <h3>{event.nombreEvento}</h3>
                  <p class="location">
                    <i class="fas fa-map-marker-alt" /> {event.lugarEvento}
                  </p>
                  <p class="description">
                    {event.descripcionEvento?.substring(0, 100)}...
                  </p>
                  <span class="btn-more">Más Información</span>
                </div>
              </a>
            ))}
          </BodyGrid>
        ) : (
          <div style="text-align: center;justify-content: center;display: flex;flex-direction: column;align-items: center;">
            <h3>No hay eventos programados en este momento.</h3>
            <p>
              Vuelve pronto para enterarte de nuestras próximas producciones.
            </p>
          </div>
        )
      }
    </Container>
  </Section>
  <Section>
    <Container variant="mid" flexDirection="column">
      <h2>Eventos Pasados</h2>
      <p>Descubre los eventos que hemos realizado en el pasado.</p>
      {
        eventosPasados.length > 0 ? (
          <BodyGrid columns={4}>
            {eventosPasados.map((event) => (
              <img src={event.image} alt={event.title} />
            ))}
          </BodyGrid>
        ) : (
          <div style="text-align: center;justify-content: center;display: flex;flex-direction: column;align-items: center;">
            <h3>No hay eventos programados en este momento.</h3>
            <p>
              Vuelve pronto para enterarte de nuestras próximas producciones.
            </p>
          </div>
        )
      }
    </Container>
  </Section>
  <FooterThreeCols slot="footer" />
</MainLayout>

<style>
  .event-card {
    background: var(--color-bg);
    border-radius: var(--border-radius-xl);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border);
    transition: all 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
    max-width: 400px;
    width: 100%;
    margin: 0 auto;
  }
  .event-card:hover {
    transform: translateY(-10px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-xl);
  }
  .image-wrapper {
    position: relative;
    height: 200px;
    overflow: hidden;
  }
  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .event-card:hover .image-wrapper img {
    transform: scale(1.1);
  }
  .date-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--color-primary);
    color: white;
    padding: 0.4rem 0.8rem;
    border-radius: var(--border-radius-md);
    font-size: 0.8rem;
    font-weight: 700;
  }
  .content {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .content h3 {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }
  .location {
    font-size: 0.9rem;
    color: var(--color-primary-light);
    margin-bottom: 1rem;
  }
  .description {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }
  .btn-more {
    margin-top: auto;
    color: var(--color-primary);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-more::after {
    content: "→";
    transition: transform 0.3s ease;
  }
  .event-card:hover .btn-more::after {
    transform: translateX(5px);
  }
</style>
