---
import MainLayout from "@layouts/MainLayout.astro";
import SEO from "@components/seo/SEO.astro";
import HeaderSticky from "@components/headers/HeaderSticky.astro";
import FooterThreeCols from "@components/footers/FooterThreeCols.astro";
import Section from "@components/base/Section.astro";
import Container from "@components/base/Container.astro";
import BodyGrid from "@components/body/BodyGrid.astro";
import eventsData from "@data/events.json";

const seoTitle = "Eventos | Indus3";
const seoDesc = "Próximos eventos, conciertos y festivales producidos por Indus3.";

const base = import.meta.env.BASE_URL;
---

<MainLayout title={seoTitle}>
  <SEO slot="seo" title={seoTitle} description={seoDesc} />
  
  <HeaderSticky slot="header" />

  <main>
    <Section variant="hero">
      <Container>
        <h1 style="text-align: center; font-size: var(--font-size-4xl); margin-bottom: var(--space-4);">Cartelera de Eventos</h1>
        <p style="text-align: center; color: var(--color-text-light); max-width: 600px; margin: 0 auto;">
          Descubre las próximas experiencias que tenemos preparadas para ti.
        </p>
      </Container>
    </Section>

    <Section>
      <Container>
        {eventsData.length > 0 ? (
          <BodyGrid columns={eventsData.length > 3 ? 3 : eventsData.length}>
            {eventsData.map(event => (
              <a href={`${base}eventos/${event.id}`} class="event-card">
                <div class="image-wrapper">
                  <img src={event.imagenPR} alt={event.nombreEvento} />
                  <div class="date-badge">{event.fechaEvento}</div>
                </div>
                <div class="content">
                  <h3>{event.nombreEvento}</h3>
                  <p class="location"><i class="fas fa-map-marker-alt"></i> {event.lugarEvento}</p>
                  <p class="description">{event.descripcionEvento?.[0].substring(0, 100)}...</p>
                  <span class="btn-more">Más Información</span>
                </div>
              </a>
            ))}
          </BodyGrid>
        ) : (
          <div style="text-align: center; padding: 4rem;">
            <h3>No hay eventos programados en este momento.</h3>
            <p>Vuelve pronto para enterarte de nuestras próximas producciones.</p>
          </div>
        )}
      </Container>
    </Section>
  </main>

  <FooterThreeCols slot="footer" />
</MainLayout>

<style>
  .event-card {
    background: var(--color-bg);
    border-radius: var(--border-radius-xl);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border);
    transition: all 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .event-card:hover {
    transform: translateY(-10px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-xl);
  }
  .image-wrapper {
    position: relative;
    height: 200px;
    overflow: hidden;
  }
  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .event-card:hover .image-wrapper img {
    transform: scale(1.1);
  }
  .date-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--color-primary);
    color: white;
    padding: 0.4rem 0.8rem;
    border-radius: var(--border-radius-md);
    font-size: 0.8rem;
    font-weight: 700;
  }
  .content {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .content h3 {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }
  .location {
    font-size: 0.9rem;
    color: var(--color-primary-light);
    margin-bottom: 1rem;
  }
  .description {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }
  .btn-more {
    margin-top: auto;
    color: var(--color-primary);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-more::after {
    content: "→";
    transition: transform 0.3s ease;
  }
  .event-card:hover .btn-more::after {
    transform: translateX(5px);
  }
</style>
