---
import MainLayout from "@layouts/MainLayout.astro";
import HeaderSticky from "@components/headers/HeaderSticky.astro";
import FooterThreeCols from "@components/footers/FooterThreeCols.astro";
import Section from "@components/base/Section.astro";
import Container from "@components/base/Container.astro";
import SEO from "@components/seo/SEO.astro";
import Redes from "@components/base/Redes.astro";
import { websiteSchema, organizationSchema } from "@utils/seo";

const seoTitle = `Guías y Consejos para ir a Conciertos en 2026 | Indus3`;
const seoDesc = `Prepárate para la mejor experiencia en vivo. Logística, seguridad y tips expertos para tus conciertos en 2026.`;

const sections = [
  { id: "antes", title: "Antes del evento", icon: "calendar" },
  { id: "durante", title: "Durante el show", icon: "music" },
  { id: "despues", title: "Después del evento", icon: "home" }
];
--- 

<MainLayout title={seoTitle}>
    <SEO 
      slot="seo" 
      title={seoTitle} 
      description={seoDesc} 
      schemas={[websiteSchema, organizationSchema]} 
    />
  <HeaderSticky slot="header" />

  <main class="guide-page">
    <!-- Hero Section -->
    <header class="hero">
      <div class="hero-glow"></div>
      <Container>
        <div class="hero-content">
          <span class="badge">Guía Experta 2026</span>
          <h1>Guías y Consejos para ir a Conciertos</h1>
          <p class="hero-subtitle">Ir a un concierto es una inversión de tiempo y energía. La logística es lo que separa una noche épica de un mal recuerdo. Ya sea en un estadio o en un festival, esta guía de conciertos te prepara para una experiencia brutal.</p>
          
          <nav class="quick-nav">
            {sections.map(sec => (
              <a href={`#${sec.id}`} class="nav-link">
                <span>{sec.title}</span>
              </a>
            ))}
          </nav>
        </div>
      </Container>
    </header>

    <Section>
      <Container>
        <div class="content-wrapper">
          
          <!-- Antes del evento: La preparación es clave -->
          <article id="antes" class="guide-card glass-card">
            <div class="card-header">
              <div class="icon-circle">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
              </div>
              <h2>Antes del evento: La preparación es clave</h2>
            </div>
            
            <p class="intro-p">No dejes todo para última hora. El éxito de la jornada depende de lo que hagas días antes del gran día.</p>
            
            <div class="sub-section">
              <h3>El Checklist del "Pana preparado"</h3>
              <div class="table-container">
                <table class="modern-table">
                  <thead>
                    <tr>
                      <th>Artículo</th>
                      <th>Importancia</th>
                      <th>Tip de Seguridad</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td class="item-name">Cédula / Documento</td>
                      <td><span class="status-badge high">Obligatorio</span></td>
                      <td>Ten una foto en tu celular como respaldo.</td>
                    </tr>
                    <tr>
                      <td class="item-name">Powerbank</td>
                      <td><span class="status-badge high">Alta</span></td>
                      <td>Guárdalo en una bolsa "Ziploc" por si llueve.</td>
                    </tr>
                    <tr>
                      <td class="item-name">Efectivo</td>
                      <td><span class="status-badge mid">Media</span></td>
                      <td>Distribúyelo en distintos bolsillos.</td>
                    </tr>
                    <tr>
                      <td class="item-name">Medicinas básicas</td>
                      <td><span class="status-badge low">Baja</span></td>
                      <td>Solo lo necesario para el día.</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <div class="sub-section">
              <h3> Lo que NO entra: Objetos Prohibidos</h3>
              <p class="intro-p">No dejes que un descuido arruine tu entrada al recinto. Generalmente, si intentas pasar estos objetos, tendrás que botarlos o regresarte a guardarlos, lo que significa perder tu lugar en la fila.</p>
              <div class="table-container">
                <table class="modern-table">
                  <thead>
                    <tr>
                      <th>Categoría</th>
                      <th>Objeto Prohibido</th>
                      <th>¿Por qué? / Alternativa</th>
                    </tr>
                  </thead>
                  <tbody>
                    <tr>
                      <td>Seguridad</td>
                      <td>Armas de cualquier tipo, objetos punzantes o cadenas pesadas.</td>
                      <td>Seguridad básica. Evita incluso correas con tachuelas grandes.</td>
                    </tr>
                    <tr>
                      <td>Clima</td>
                      <td>Paraguas o sombrillas con punta.</td>
                      <td>Obstruyen la vista y son peligrosos. Usa un poncho impermeable.</td>
                    </tr>
                    <tr>
                      <td>Tecnología</td>
                      <td>Cámaras profesionales (lentes intercambiables) o GoPros.</td>
                      <td>Derechos de transmisión. Usa la cámara de tu celular.</td>
                    </tr>
                    <tr>
                      <td>Accesorios</td>
                      <td>Selfie sticks (palos de selfie) y punteros láser.</td>
                      <td>Molestan al resto del público y al artista.</td>
                    </tr>
                    <tr>
                      <td>Comodidad</td>
                      <td>Sillas plegables, carpas o hieleras (coolers).</td>
                      <td>Por gestión de espacio y evacuación.</td>
                    </tr>
                    <tr>
                      <td>Sustancias</td>
                      <td>Bebidas alcohólicas, sustancias ilícitas o envases de vidrio/metal.</td>
                      <td>Control de ventas interno y seguridad.</td>
                    </tr>
                    <tr>
                      <td>Varios</td>
                      <td>Pancartas de cartón muy grandes o con palos.</td>
                      <td>Bloquean la visibilidad de los que están atrás.</td>
                    </tr>
                  </tbody>
                </table>
              </div>
            </div>

            <div class="tips-grid">
              <div class="tip-box pro">
                <div class="tip-tag">Tip de Pro</div>
                <p>Revisa las redes oficiales de la productora 24h antes. A veces prohíben cosas específicas como Powerbanks de gran capacidad según el nivel de seguridad.</p>
              </div>
              <div class="tip-box gold">
                <div class="tip-tag">Tip de Oro</div>
                <p>En 2026 se está volviendo obligatorio el uso de <strong>mochilas de PVC transparentes</strong> en estadios para agilizar el ingreso.</p>
              </div>
            </div>

            <div class="info-grid">
              <div class="info-item">
                <h4>Uso Inteligente del Celular</h4>
                <ul>
                  <li><strong>Memoria:</strong> Libera al menos 5GB. No quieres el aviso de "Memoria Llena" en el coro.</li>
                  <li><strong>Brillo:</strong> Bájalo un poco para ahorrar batería y no molestar a los demás.</li>
                </ul>
              </div>
              <div class="info-item">
                <h4>Outfit y Comodidad</h4>
                <ul>
                  <li><strong>Calzado:</strong> Usa zapatos ya "domados". Evita estrenar rígidos ese día.</li>
                  <li><strong>Ropa:</strong> Vístete en capas. Calor adentro, frío al salir.</li>
                </ul>
              </div>
            </div>
          </article>

          <!-- Durante el Concierto -->
          <article id="durante" class="guide-card glass-card">
            <div class="card-header">
              <div class="icon-circle">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"></path><circle cx="6" cy="18" r="3"></circle><circle cx="18" cy="16" r="3"></circle></svg>
              </div>
              <h2>Durante el Concierto: Disfruta con inteligencia</h2>
            </div>
            
            <p class="intro-p">Ya pasaste los controles, ahora toca mantener la energía con inteligencia táctica en el recinto.</p>

            <div class="feature-grid">
              <div class="feature-card">
                <h5>Logística de Grupo</h5>
                <p><strong>Puntos de encuentro:</strong> Fijen un lugar físico apenas lleguen. En eventos grandes la señal suele caerse por completo.</p>
              </div>
              <div class="feature-card">
                <h5>Salud en el foso</h5>
                <p><strong>Hidratación estratégica:</strong> Ubica los puestos de agua. Bebe constante pero en sorbos pequeños.</p>
              </div>
            </div>

            <div class="safety-banner">
              <div class="safety-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
              </div>
              <div class="safety-content">
                <h4>Seguridad Personal: La Regla "Todo al Frente"</h4>
                <ul>
                  <li><strong>Mochilas al pecho:</strong> En aglomeraciones, gira tu bolso hacia adelante.</li>
                  <li><strong>Koalas cruzados:</strong> Mantén tus pertenencias pegadas a tu pecho.</li>
                  <li><strong>Cierres:</strong> Nunca uses los bolsillos traseros. Si hay cierres, úsalos.</li>
                </ul>
              </div>
            </div>
          </article>

          <!-- Despues del Concierto -->
          <article id="despues" class="guide-card glass-card">
            <div class="card-header">
              <div class="icon-circle">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
              </div>
              <h2>Después del Show: El retorno seguro</h2>
            </div>
            
            <p class="intro-p">El concierto terminó y la adrenalina está alta, pero el cuerpo y tu seguridad personal son prioridad.</p>
            
            <div class="info-grid">
              <div class="info-item">
                <h4>Salida y Transporte</h4>
                <p>Espera 15 minutos a que baje el flujo masivo. Si usas apps de transporte, camina unas cuadras lejos para evitar tarifas dinámicas extremas.</p>
              </div>
              <div class="info-item">
                <h4>Recuperación Física</h4>
                <p>Al llegar, estira pantorrillas y espalda. Si sientes pitido de oídos (tinnitus), evita ruidos fuertes por las próximas 24 horas.</p>
              </div>
            </div>
          </article>

          <!-- Guía creada por Indus3, siguenos en todas nuestras redes -->
          <footer class="guide-footer glass-card">
            <span class="footer-text">Guía creada por <strong style="color:var(--color-primary);">Indus3</strong></span>
            <p>Síguenos en nuestras redes para más contenido exclusivo</p>
            <Redes variant="minimal" className="footer-socials" />
          </footer>
        </div>
      </Container>
    </Section>
  </main>

  <FooterThreeCols slot="footer" />
</MainLayout>

<style>
  html {
    scroll-behavior: smooth;
  }

  .guide-page {
    background-color: var(--color-bg);
    color: var(--color-text);
  }

  /* Hero Section */
  .hero {
    position: relative;
    padding: var(--space-16) 0 0 0 ;
    text-align: center;
    overflow: hidden;
    background: linear-gradient(to bottom, #111827, var(--color-bg));
  }

  .hero-glow {
    position: absolute;
    top: calc(var(--space-16) * -1);
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: calc(100% + var(--space-16) + var(--space-4));
    background: radial-gradient(circle, rgba(59, 130, 246, 0.15) 0%, transparent 70%);
    z-index: 0;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
  }

  .badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: rgba(59, 130, 246, 0.1);
    color: var(--color-primary);
    border-radius: var(--border-radius-full);
    font-size: var(--font-size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid rgba(59, 130, 246, 0.2);
    margin-bottom: var(--space-6);
  }

  .hero h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    line-height: 1.1;
    font-weight: 900;
    margin-bottom: var(--space-6);
    background: linear-gradient(135deg, var(--color-text) 0%, var(--color-primary) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: var(--font-size-xl);
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: var(--space-10);
  }

  /* Quick Nav */
  .quick-nav {
    display: flex;
    justify-content: center;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .nav-link {
    padding: var(--space-2) var(--space-6);
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius-lg);
    font-weight: 500;
    transition: all var(--transition-base);
    color: var(--color-text);
  }

  .nav-link:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-2px);
    border-color: var(--color-primary);
    text-decoration: none;
  }

  /* Content Layout */
  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    max-width: 900px;
    margin: 0 auto;
  }

  /* Cards Stylings */
  .glass-card {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: var(--border-radius-2xl);
    padding: var(--space-10);
    position: relative;
    transition: transform var(--transition-base);
    scroll-margin-top: calc(var(--height-header) + var(--space-8));
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .icon-circle {
    width: 48px;
    height: 48px;
    background: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: 0 8px 16px rgba(59, 130, 246, 0.2);
  }

  .glass-card h2 {
    font-size: var(--font-size-3xl);
    font-weight: 800;
    margin: 0;
  }

  .intro-p {
    font-size: var(--font-size-lg);
    color: var(--color-text-light);
    margin-bottom: var(--space-8);
  }

  /* Table Style */
  .table-container {
    overflow-x: auto;
    margin-bottom: var(--space-8);
    border-radius: var(--border-radius-xl);
    border: 1px solid var(--color-border);
  }

  .modern-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    background: rgba(0, 0, 0, 0.2);
  }

  .modern-table th {
    background: rgba(255, 255, 255, 0.05);
    padding: var(--space-4);
    font-weight: 700;
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .modern-table td {
    padding: var(--space-4);
    border-top: 1px solid rgba(255, 255, 255, 0.05);
  }

  .item-name {
    font-weight: 600;
    color: var(--color-text);
  }

  .status-badge {
    padding: 2px 10px;
    border-radius: var(--border-radius-full);
    font-size: var(--font-size-xs);
    font-weight: 700;
  }

  .status-badge.high { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
  .status-badge.mid { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }
  .status-badge.low { background: rgba(16, 185, 129, 0.1); color: #10b981; }

  /* Tips Grid */
  .tips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  .tip-box {
    padding: var(--space-6);
    border-radius: var(--border-radius-xl);
    border-left: 4px solid;
    background: rgba(255, 255, 255, 0.02);
  }

  .tip-box.pro { border-color: var(--color-primary); }
  .tip-box.gold { border-color: var(--color-accent); }

  .tip-tag {
    font-size: var(--font-size-xs);
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
    color: inherit;
    opacity: 0.8;
  }

  /* Info/Feature Grids */
  .info-grid, .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: var(--space-8);
  }

  .info-item h4, .feature-card h5 {
    font-size: var(--font-size-xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    color: var(--color-primary);
  }

  .info-item ul {
    list-style: none;
    padding: 0;
  }

  .info-item li {
    margin-bottom: var(--space-3);
    padding-left: var(--space-6);
    position: relative;
    line-height: 1.5;
  }

  .info-item li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--color-primary);
  }

  /* Safety Banner */
  .safety-banner {
    display: flex;
    gap: var(--space-6);
    background: rgba(245, 158, 11, 0.05);
    border: 1px solid rgba(245, 158, 11, 0.2);
    padding: var(--space-8);
    border-radius: var(--border-radius-xl);
    margin-top: var(--space-4);
  }

  .safety-content h4 {
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  /* Dark mode overrides if needed */
  @media (prefers-color-scheme: light) {
    .glass-card {
      background: rgba(255, 255, 255, 0.8);
      border-color: var(--color-border);
      box-shadow: var(--shadow-lg);
    }
    .modern-table { background: #fff; }
    .modern-table th { background: #f9fafb; color: #374151; }
    .hero { background: linear-gradient(to bottom, #f3f4f6, #fff); }
    .hero h1 { background: linear-gradient(135deg, #111827 0%, var(--color-primary) 100%); -webkit-background-clip: text; }
  }

  @media (max-width: 768px) {
    .glass-card { 
      padding: var(--space-6); 
      scroll-margin-top: calc(var(--height-header-mobile) + var(--space-4));
    }
    .tips-grid, .info-grid { grid-template-columns: 1fr; }
    .safety-banner { flex-direction: column; gap: var(--space-4); }
  }

  /* Guide Footer */
  .guide-footer {
    text-align: center;
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    align-items: center;
    display: flex;
    flex-direction: column;
  }

  .footer-text {
    font-size: var(--font-size-lg);
    color: var(--color-text);
  }

  .guide-footer p {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
  }

  .footer-socials {
    margin-top: var(--space-2);
  }
</style>
