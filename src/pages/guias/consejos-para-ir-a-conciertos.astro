---
import MainLayout from "@layouts/MainLayout.astro";
import HeaderSticky from "@components/headers/HeaderSticky.astro";
import FooterThreeCols from "@components/footers/FooterThreeCols.astro";
import Section from "@components/base/Section.astro";
import Container from "@components/base/Container.astro";
import SEO from "@components/seo/SEO.astro";
import Redes from "@components/base/Redes.astro";
import { websiteSchema, organizationSchema } from "@utils/seo";

const seoTitle = `Guías y Consejos para ir a Conciertos en 2026 | Indus3`;
const seoDesc = `Prepárate para la mejor experiencia en vivo. Logística, seguridad y tips expertos para tus conciertos en 2026.`;

const sections = [
  { id: "antes", title: "Antes del evento", icon: "calendar" },
  { id: "durante", title: "Durante el show", icon: "music" },
  { id: "despues", title: "Después del evento", icon: "home" },
];
---

<MainLayout title={seoTitle}>
  <SEO
    slot="seo"
    title={seoTitle}
    description={seoDesc}
    schemas={[websiteSchema, organizationSchema]}
  />
  <HeaderSticky slot="header" />

  <Section>

    <Container flexDirection="column" variant="mid">
      <div class="content-wrapper">
        <h1>
          Cómo prepararte para ir a conciertos en 2026:<br> 10 consejos para
          disfrutar al máximo
        </h1>
        <p>
          Ir a un concierto es una inversión de tiempo y energía. La logística
          es lo que separa una noche épica de un mal recuerdo. Ya sea en un
          estadio o en un festival, esta guía de conciertos te prepara para el
          antes, durante y despues del evento y así vivas una experiencia
          brutal.
        </p>
        <div class="recom-container">
          <h2>Recomendaciones para asistir conciertos</h2>
          <ol>
            <li>
              <a href="#checklist">Prepara los artículos esenciales</a>
            </li>
            <li>
              <a href="#objetos-prohibidos">Evita objetos prohibidos</a>
            </li>
            <li>
              <a href="#redes-oficiales"
                >Revisa las redes oficiales de la productora 24 horas antes</a
              >
            </li>
            <li>
              <a href="#celular">Usa el celular de forma inteligente</a>
            </li>
            <li>
              <a href="#ropa">Usa ropa adecuada</a>
            </li>
            <li>
              <a href="#punto-encuentro">Establece un punto de encuentro</a>
            </li>
            <li>
              <a href="#hidratacion">Mantén una hidratación constante</a>
            </li>
            <li>
              <a href="#seguridad">Mantén tus artículos personales seguros</a>
            </li>
            <li>
              <a href="#transporte">Planifica tu salida y transporte</a>
            </li>
            <li>
              <a href="#recuperacion">Recupérate físicamente</a>
            </li>
          </ol>
        </div>

        <!-- Antes del evento: La preparación es clave -->
        <article class="glass-card">
          <p class="intro-p">
            No dejes todo para última hora. El éxito de la jornada depende de lo
            que hagas días antes del gran día.
          </p>
          <div class="recom-container">
            <h2 id="checklist">1. Prepara los artículos esenciales</h2>
            <table class="modern-table">
              <thead>
                <tr>
                  <th>Artículo</th>
                  <th>Importancia</th>
                  <th>Tip de Seguridad</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="item-name">Entrada + Cédula / Documento</td>
                  <td>
                    <p class="column">
                      <span class="status-badge high">Obligatorio</span>
                      <span class="small-text">(Entrada al recinto).</span>
                    </p>
                  </td>
                  <td>Ten una foto en tu celular como respaldo.</td>
                </tr>
                <tr>
                  <td class="item-name">Powerbank</td>
                  <td>
                    <p class="column">
                      <span class="status-badge high">Alta</span>
                      <span class="small-text"
                        >(Para no quedarte incomunicado).</span
                      >
                    </p>
                  </td>
                  <td>Guárdalo en una bolsa "Ziploc" por si llueve.</td>
                </tr>
                <tr>
                  <td class="item-name">Efectivo</td>
                  <td>
                    <p class="column">
                      <span class="status-badge mid">Media</span>
                      <span class="small-text"
                        >(Por si fallan los puntos de venta).</span
                      >
                    </p>
                  </td>
                  <td>Distribúyelo en distintos bolsillos.</td>
                </tr>
                <tr>
                  <td class="item-name">Medicinas básicas</td>
                  <td>
                    <p class="column">
                      <span class="status-badge low">Baja/Media</span>
                      <span class="small-text"
                        >(Dolor de cabeza o digestión).</span
                      >
                    </p>
                  </td>
                  <td>Solo lo necesario para el día.</td>
                </tr>
              </tbody>
            </table>
          </div>

          <div class="recom-container">
            <h2 id="objetos-prohibidos">2. Evita objetos prohibidos</h2>
            <p class="intro-p">
              No dejes que un descuido arruine tu entrada al recinto.
              Generalmente, si intentas pasar estos objetos, tendrás que
              botarlos o regresarte a guardarlos, lo que significa perder tu
              lugar en la fila.
            </p>
          </div>

          <table class="modern-table">
            <thead>
              <tr>
                <th>Categoría</th>
                <th>Objeto Prohibido</th>
                <th>¿Por qué? / Alternativa</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td class="item-name">Seguridad</td>
                <td
                  >Armas de cualquier tipo, objetos punzantes o cadenas pesadas.</td
                >
                <td
                  >Seguridad básica. Evita incluso correas con tachuelas
                  grandes.</td
                >
              </tr>
              <tr>
                <td class="item-name">Clima</td>
                <td>Paraguas o sombrillas con punta.</td>
                <td
                  >Obstruyen la vista y son peligrosos. Usa un poncho
                  impermeable.</td
                >
              </tr>
              <tr>
                <td class="item-name">Tecnología</td>
                <td>Cámaras profesionales (lentes intercambiables) o GoPros.</td
                >
                <td>Derechos de transmisión. Usa la cámara de tu celular.</td>
              </tr>
              <tr>
                <td class="item-name">Accesorios</td>
                <td>Selfie sticks (palos de selfie) y punteros láser.</td>
                <td>Molestan al resto del público y al artista.</td>
              </tr>
              <tr>
                <td class="item-name">Comodidad</td>
                <td>Sillas plegables, carpas o hieleras (coolers).</td>
                <td>Por gestión de espacio y evacuación.</td>
              </tr>
              <tr>
                <td class="item-name">Sustancias</td>
                <td
                  >Bebidas alcohólicas, sustancias ilícitas o envases de
                  vidrio/metal.</td
                >
                <td>Control de ventas interno y seguridad.</td>
              </tr>
              <tr>
                <td class="item-name">Varios</td>
                <td>Pancartas de cartón muy grandes o con palos.</td>
                <td>Bloquean la visibilidad de los que están atrás.</td>
              </tr>
            </tbody>
          </table>

          <div class="recom-container">
            <h2 id="redes-oficiales">
              3. Revisa las redes oficiales de la productora 24 horas antes
            </h2>
            <div class="tip-box pro">
              <span
                >A veces prohíben cosas específicas como Powerbanks de gran
                capacidad según el nivel de seguridad.</span
              >
            </div>
          </div>
          <div class="tip-box gold">
            <div class="tip-tag">
              <h3>Tip de Oro</h3>
            </div>
            <span
              >En 2026 se está volviendo obligatorio el uso de <strong
                >mochilas de PVC transparentes</strong
              > en estadios para agilizar el ingreso.</span
            >
          </div>
          <div class="recom-container">
            <h2 id="celular">4. Usa el celular de forma inteligente</h2>
            <ul>
              <li>
                <strong>Memoria:</strong> Libera al menos 5GB. No quieres el aviso
                de "Memoria Llena" en el coro.
              </li>
              <li>
                <strong>Brillo:</strong> Bájalo un poco para ahorrar batería y no
                molestar a los demás.
              </li>
            </ul>
          </div>

          <div class="recom-container">
            <h2 id="ropa">5. Usa ropa adecuada</h2>
            <ul>
              <li>
                <span
                  ><strong>Calzado:</strong> Usa zapatos ya "domados". Evita estrenar
                  rígidos ese día.</span>
              </li>
              <li>
                <span
                  ><strong>Ropa:</strong> Vístete en capas. Calor adentro, frío al
                  salir.</span>
              </li>
              <li>
                <span
                  ><strong>Tips para Mujeres:</strong>
                  <ul>
                    <li>Biker shorts: Úsalos debajo de faldas o vestidos para moverte, sentarte y saltar con total libertad y sin roces.</li>
                    <li>Pelo y joyas: Lleva siempre una liga en la muñeca para el calor y evita accesorios largos que se puedan enredar o golpear con la multitud.</li>
                    <li>Seguridad y frescura: Bolso siempre al frente, maquillaje a prueba de agua y un paquete de pañuelos para sobrevivir a la falta de suministros en los baños.</li>
                  </ul>
                </span>
              </li>
            </ul>
          </div>

          <p class="intro-p">
            Ya pasaste los controles, ahora toca mantener la energía con
            inteligencia táctica en el recinto.
          </p>
          <div class="recom-container">
            <h2 id="punto-de-encuentro">6. Establece un punto de encuentro</h2>
            <p>
              Fijen un lugar físico apenas lleguen. En eventos grandes la señal
              suele caerse por completo.
            </p>
          </div>
          <div class="recom-container">
            <h2 id="hidratacion">7. Mantén una hidratación constante</h2>
            <p>
              Ubica los puestos de agua. Bebe constante pero en sorbos pequeños.
            </p>
          </div>
          <div class="recom-container">
            <h2 id="seguridad">8. Mantén tus artículos personales seguros</h2>
            <ul>
              <li>
                <strong>Mochilas al pecho:</strong> En aglomeraciones, gira tu bolso
                hacia adelante.
              </li>
              <li>
                <strong>Koalas cruzados:</strong> Mantén tus pertenencias pegadas
                a tu pecho.
              </li>
              <li>
                <strong>Cierres:</strong> Nunca uses los bolsillos traseros. Si hay
                cierres, úsalos.
              </li>
            </ul>
          </div>

          <!-- Despues del Concierto -->

          <p class="intro-p">
            El concierto terminó y la adrenalina está alta, pero el cuerpo y tu
            seguridad personal son prioridad.
          </p>
          <div class="recom-container">
            <h2 id="transporte">9. Planifica tu salida y transporte</h2>
            <p>
              Espera 15 minutos a que baje el flujo masivo. Si usas apps de
              transporte, camina unas cuadras lejos para evitar tarifas
              dinámicas extremas.
            </p>
          </div>
          <div class="recom-container">
            <h2 id="recuperacion">10. Recupérate físicamente</h2>
            <p>
              Al llegar, estira pantorrillas y espalda. Si sientes pitido de
              oídos (tinnitus), evita ruidos fuertes por las próximas 24 horas.
            </p>
          </div>
        </article>

        <!-- Guía creada por Indus3, siguenos en todas nuestras redes -->
        <footer class="guide-footer glass-card">
          <span class="footer-text"
            >Guía creada por <strong style="color:var(--color-primary);"
              >Indus3</strong
            ></span
          >
          <p>Síguenos en nuestras redes para más contenido exclusivo</p>
          <Redes />
        </footer>
      </div>
    </Container>
  </Section>

  <FooterThreeCols slot="footer" />
</MainLayout>

<style>
  html {
    scroll-behavior: smooth;
  }
  .recom-container {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .guide-page {
    background-color: var(--color-bg);
    color: var(--color-text);
  }

  /* Hero Section */
  .hero {
    position: relative;
    padding: var(--space-16) 0 0 0;
    text-align: center;
    overflow: hidden;
  }

  .hero-glow {
    position: absolute;
    top: calc(var(--space-16) * -1);
    left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: calc(100% + var(--space-16) + var(--space-4));
    z-index: 0;
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    margin: 0 auto;
    gap: var(--space-6);
    display: flex;
    flex-direction: column;
  }

  .badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background: rgba(59, 130, 246, 0.1);
    color: var(--color-primary);
    border-radius: var(--border-radius-full);
    font-size: var(--font-size-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    border: 1px solid rgba(59, 130, 246, 0.2);
    margin-bottom: var(--space-6);
  }

  /* Content Layout */
  .content-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    max-width: 900px;
    margin: 0 auto;
  }

  /* Cards Stylings */
  .glass-card {
    /* background: rgba(255, 255, 255, 0.03); */
    backdrop-filter: blur(20px);
    /* border: 1px solid rgba(255, 255, 255, 0.05); */
    border-radius: var(--border-radius-2xl);
    /* padding: var(--space-10); */
    position: relative;
    transition: transform var(--transition-base);
    scroll-margin-top: calc(var(--height-header) + var(--space-8));
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .card-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .icon-circle {
    width: 48px;
    height: 48px;
    background: var(--color-primary);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    box-shadow: 0 8px 16px rgba(59, 130, 246, 0.2);
  }

  .glass-card h2 {
    font-weight: 800;
    margin: 0;
  }

  /* Table Style */
  .table-container {
    overflow-x: auto;
    margin-bottom: var(--space-8);
    border-radius: var(--border-radius-xl);
    border: 1px solid var(--color-border);
  }

  .modern-table {
    width: 100%;
    border-collapse: collapse;
    text-align: left;
    background: var(--color-bg-alt);
  }

  .modern-table th {
    background: var(--color-bg-alt);
    padding: var(--space-4);
    font-weight: 700;
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    text-align: center;
  }

  .modern-table td {
    padding: var(--space-4);
    border-top: 1px solid rgba(0, 0, 0, 0.219);
  }

  .item-name {
    font-weight: 600;
    color: var(--color-text);
  }

  .status-badge {
    padding: 2px 10px;
    border-radius: var(--border-radius-full);
    font-size: var(--font-size-xs);
    font-weight: 700;
    width: fit-content;
  }

  .status-badge.high {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
  }
  .status-badge.mid {
    background: rgba(245, 158, 11, 0.1);
    color: #f59e0b;
  }
  .status-badge.low {
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
  }

  /* Tips Grid */
  .tips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-10);
  }

  .tip-box {
    padding: var(--space-6);
    border-radius: var(--border-radius-xl);
    border-left: 4px solid;
    background: var(--color-bg-alt);
  }

  .tip-box.pro {
    border-color: var(--color-primary);
  }
  .tip-box.gold {
    border-color: var(--color-accent);
  }

  .tip-tag {
    font-size: var(--font-size-xs);
    font-weight: 800;
    text-transform: uppercase;
    margin-bottom: var(--space-2);
    color: inherit;
    opacity: 0.8;
  }

  /* Info/Feature Grids */
  .info-grid,
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: var(--space-8);
  }

  .info-item h3,
  .feature-card h5 {
    font-size: var(--font-size-xl);
    font-weight: 700;
    margin-bottom: var(--space-4);
    color: var(--color-primary);
  }

  .info-item ul {
    list-style: none;
    padding: 0;
  }

  .info-item li {
    margin-bottom: var(--space-3);
    padding-left: var(--space-6);
    position: relative;
    line-height: 1.5;
  }

  .info-item li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--color-primary);
  }

  /* Safety Banner */
  .safety-banner {
    display: flex;
    gap: var(--space-6);
    background: rgba(245, 158, 11, 0.05);
    border: 1px solid rgba(245, 158, 11, 0.2);
    padding: var(--space-8);
    border-radius: var(--border-radius-xl);
    margin-top: var(--space-4);
  }

  .safety-content h3 {
    color: var(--color-accent);
    margin-bottom: var(--space-4);
  }

  .column {
    display: flex;
    flex-direction: column;
  }

  .small-text {
    font-size: var(--font-size-xs);
    font-weight: 400;
    text-align: left;
  }

  ul {
    list-style-type: disc;
  }
  p {
    margin-bottom: 0;
  }


  /* Guide Footer */
  .guide-footer {
    text-align: center;
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-2);
    align-items: center;
    display: flex;
    flex-direction: column;
  }

  .footer-text {
    font-size: var(--font-size-lg);
    color: var(--color-text);
  }

  .guide-footer p {
    font-size: var(--font-size-sm);
    color: var(--color-text-light);
    margin-bottom: var(--space-4);
  }

  .footer-socials {
    margin-top: var(--space-2);
  }
  
  /* Estilos para Modo Claro (cuando NO está activa la clase .dark) */
  /* :global(html:not(.dark)) .glass-card {
    background: rgba(255, 255, 255, 0.8);
    border-color: var(--color-border);
    box-shadow: var(--shadow-lg);
  } */

  :global(html:not(.dark)) .modern-table {
    background: #e7e7e7;
  }

  :global(html:not(.dark)) .modern-table th {
    background: #cccccc;
    color: #374151;
  }

  @media (max-width: 768px) {
    .glass-card {
      scroll-margin-top: calc(var(--height-header-mobile) + var(--space-4));
    }
    .tips-grid,
    .info-grid {
      grid-template-columns: 1fr;
    }
    .safety-banner {
      flex-direction: column;
      gap: var(--space-4);
    }
    .modern-table th{
      padding:var(--space-2)
    }
    .modern-table td{
      padding:var(--space-2)
    }
  }
</style>

<script>
  function setupSmoothScroll() {
    document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener("click", function (e) {
        const href = this.getAttribute("href");
        if (!href || href === "#") return;

        const target = document.querySelector(href);
        if (target) {
          e.preventDefault();

          // Obtenemos la altura del header desde la variable CSS o usamos 80 por defecto
          const headerHeight =
            parseInt(
              getComputedStyle(document.documentElement).getPropertyValue(
                "--height-header",
              ),
            ) || 80;
          const extraMargin = 20; // Margen adicional para que respire el título

          // Calculamos la posición destino
          const elementPosition =
            target.getBoundingClientRect().top + window.scrollY;
          const offsetPosition = elementPosition - headerHeight - extraMargin;

          window.scrollTo({
            top: offsetPosition,
            behavior: "smooth",
          });

          // Opcional: Actualizar la URL sin saltar
          history.pushState(null, null, href);
        }
      });
    });
  }

  // Inicializar
  setupSmoothScroll();

  // Re-inicializar si usas Astro View Transitions
  document.addEventListener("astro:after-swap", setupSmoothScroll);
</script>
