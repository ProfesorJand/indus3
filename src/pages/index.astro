<style>
    .artist-grid {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: var(--space-8);
      margin-bottom: var(--space-12);
    }

    .artist-grid > :global(*) {
      flex: 0 0 calc(12.5% - var(--space-8));
      min-width: 120px;
    }

    @media (max-width: 1400px) {
      .artist-grid > :global(*) {
        flex: 0 0 calc(16.66% - var(--space-8));
      }
    }

    @media (max-width: 1024px) {
      .artist-grid > :global(*) {
        flex: 0 0 calc(25% - var(--space-8));
      }
    }

    @media (max-width: 640px) {
      .artist-grid {
        gap: var(--space-4);
      }
      .artist-grid > :global(*) {
        flex: 0 0 calc(50% - var(--space-4));
      }
    }
  </style>
