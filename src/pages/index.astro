---

<MainLayout title={seoTitle}>
  <SEO 
    slot="seo" 
    title={seoTitle} 
    description={seoDesc} 
    schemas={[websiteSchema, organizationSchema]} 
  />

  <HeaderSticky slot="header" />

  <Section variant="hero">
    <Container>
      <Slider slides={slides} />
    </Container>
  </Section>

  <!-- Hero Section (Full Width example) -->
  <Section variant="fullHeightWithHeader">
    <Container>
      <div style="text-align: center; max-width: 800px; margin: 0 auto;">
        <h1 style="font-size: var(--font-size-4xl); margin-bottom: var(--space-6);">
          Boilerplate Modular para <span style="color: var(--color-primary);">Frontend Moderno</span>
        </h1>
        <p style="font-size: var(--font-size-xl); color: var(--color-text-light); margin-bottom: var(--space-8);">
          Construye sitios web de alto rendimiento combinando headers, layouts y footers intercambiables.
        </p>
        <div style="display: flex; gap: var(--space-4); justify-content: center;">
          <Button size="large">Comenzar Ahora</Button>
          <Button variant="outline" size="large">Ver Documentación</Button>
        </div>
      </div>
    </Container>
  </Section>

  <!--Card Carrusel -->
  <Section variant="alt">
    <Container>
      <CardCarousel cards={cards} title="Productos Destacados" />
    </Container>
  </Section>

  <!-- Content with Sidebar Example -->
  <Section variant="alt">
    <BodyTwoColumns sidebarLeft={true}>
      <div slot="sidebar">
        <h3 style="margin-bottom: var(--space-4);">Categorías</h3>
        <ul style="display: flex; flex-direction: column; gap: var(--space-2);">
          <li><a href="#" style="color: var(--color-primary);">Diseño Web</a></li>
          <li><a href="#">Arquitectura React</a></li>
          <li><a href="#">Rendimiento Astro</a></li>
          <li><a href="#">Nanostores State</a></li>
        </ul>
      </div>

      <h2>Arquitectura de Software Senior</h2>
      <p style="margin: var(--space-4) 0 var(--space-8);">
        Este starter kit utiliza lo mejor del ecosistema moderno: Astro para el esqueleto y React par la interactividad donde sea estrictamente necesario.
      </p>

      <BodyGrid>
        <Card 
          title="Componentes Base" 
          description="Botones, contenedores y secciones listos para usar con CSS Modules."
          image="https://images.unsplash.com/photo-1555066931-4365d14bab8c?auto=format&fit=crop&q=80&w=400"
        />
        <Card 
          title="CSS Modules" 
          description="Estilos aislados y escalables sin conflictos, siguiendo la filosofía BEM."
          image="https://images.unsplash.com/photo-1507721999472-8ed4421c4af2?auto=format&fit=crop&q=80&w=400"
        />
        <Card 
          title="SEO Avanzado" 
          description="Metadatos dinámicos y esquemas JSON-LD integrados por defecto."
          image="https://images.unsplash.com/photo-1451187580459-43490279c0fa?auto=format&fit=crop&q=80&w=400"
        />
      </BodyGrid>
    </BodyTwoColumns>
  </Section>

  <FooterThreeCols slot="footer" />
</MainLayout>

