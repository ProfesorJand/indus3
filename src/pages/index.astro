const projectRoot = process.cwd();
const clientesDir = path.resolve(projectRoot, 'public/clientes');
const clientsDir = path.resolve(projectRoot, 'public/clientes-venezolanos');
const clientsDir2 = path.resolve(projectRoot, 'public/clientes-de-la-region');

let files: string[] = [];

try {
  files = fs.readdirSync(clientsDir);
  if (files.length === 0) console.warn('Warning: No files found in', clientsDir);
} catch (error) {
  console.error('Error reading clients directory:', error);
}

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, "");

const clientesVenezolanos = files
  .filter(file => /\.(webp|png|jpg|jpeg|svg)$/i.test(file))
  .map(file => {
    const nameWithoutExt = file.replace(/\.[^/.]+$/, "");
    // Remove "Logo-" prefix and replace hyphens with spaces
    const title = nameWithoutExt
      .replace(/^Logo-/i, "")
      .replace(/-/g, " ");
    
    return {
      image: `${baseUrl}/clientes-venezolanos/${file}`,
      title: title,
      link: "/#"
    };

  });

