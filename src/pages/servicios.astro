---
import MainLayout from "@layouts/MainLayout.astro";
import SEO from "@components/seo/SEO.astro";
import { websiteSchema, organizationSchema } from "@utils/seo";
import HeaderSticky from "@components/headers/HeaderSticky.astro";
import FooterThreeCols from "@components/footers/FooterThreeCols.astro";
import Section from "@components/base/Section.astro";
import Container from "@components/base/Container.astro";
import BodyGrid from "@components/body/BodyGrid.astro";
import Card from "@components/base/Card.astro";

const seoTitle = "Nuestros Servicios";
const seoDesc = "Agencia 360 de comunicaciones, marketing y producción de eventos. Booking, conciertos, festivales y mucho más.";

const highLevelServices = [
  "Booking agency.",
  "Producción general de eventos.",
  "Desarrollo, planificación y ejecución de conciertos, festivales, exposiciones y eventos.",
  "Agencia 360 de comunicaciones y marketing.",
  "Y mucho más..."
];

const serviceCategories = [
  {
    title: "Corporativo",
    icon: "fas fa-briefcase",
    items: [
      "Eventos (lanzamientos, ruedas de prensa, fiestas)",
      "Promociones en PDV",
      "Actividades BTL",
      "Convenciones de ventas"
    ]
  },
  {
    title: "Musicales",
    icon: "fas fa-music",
    items: [
      "Conciertos",
      "Festivales",
      "Giras nacionales e internacionales",
      "Booking artistas (nacionales e internacionales)"
    ]
  },
  {
    title: "Entretenimiento",
    icon: "fas fa-smile-beam",
    items: [
      "Exposiciones",
      "Charlas y conferencias",
      "Deporte",
      "Esports",
      "Circos y shows temáticos"
    ]
  }
];
---

<MainLayout title={seoTitle}>
  <SEO 
    slot="seo" 
    title={seoTitle} 
    description={seoDesc} 
    schemas={[websiteSchema, organizationSchema]} 
  />

  <HeaderSticky slot="header" />

  <main>
    <!-- Hero Section -->
    <Section variant="hero" className="services-hero">
      <Container>
        <div style="max-width: 800px; margin: 0 auto; text-align: center;">
          <h1 style="font-size: var(--font-size-4xl); margin-bottom: var(--space-4); color: var(--color-primary);">Nuestros Servicios</h1>
          <p style="font-size: var(--font-size-xl); margin-bottom: var(--space-8); font-weight: 500;">
            Somos los arquitectos de la emoción, transformando ideas en experiencias que trascienden.
          </p>
          
          <div style="background: rgba(255, 255, 255, 0.05); padding: var(--space-8); border-radius: var(--border-radius-xl); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.1); text-align: left;">
            <p style="font-weight: 600; margin-bottom: var(--space-4); font-size: var(--font-size-lg);">Prestamos servicios de:</p>
            <ul style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: var(--space-3); list-style: none; padding: 0;">
              {highLevelServices.map(service => (
                <li style="display: flex; align-items: flex-start; gap: var(--space-2);">
                  <i class="fas fa-check-circle" style="color: var(--color-primary); margin-top: 4px;"></i>
                  <span>{service}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </Container>
    </Section>

    <!-- Detailed Services Grid -->
    <Section variant="alt">
      <Container>
        <h2 style="text-align: center; margin-bottom: var(--space-12); font-size: var(--font-size-3xl);">Especialidades por Área</h2>
        <BodyGrid>
          {serviceCategories.map(category => (
            <div style="background: var(--color-bg); padding: var(--space-8); border-radius: var(--border-radius-lg); border: 1px solid var(--color-border); transition: transform 0.3s ease; height: 100%;" class="service-category-card">
              <div style="width: 60px; height: 60px; justify-self:center; background: var(--color-primary-light); color: var(--color-primary); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: var(--space-2); font-size: 1.5rem;">
                <i class={category.icon}></i>
              </div>
              <h3 style="justify-self:center; font-size: var(--font-size-2xl); margin-bottom: var(--space-4);">{category.title}</h3>
              <ul style="list-style: none; padding: 0; display: flex; flex-direction: column; gap: var(--space-3);">
                {category.items.map(item => (
                  <li style="color: var(--color-text-light); display: flex; align-items: center; gap: var(--space-2);">
                    <span style="width: 6px; height: 6px; background: var(--color-primary); border-radius: 50%;"></span>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </BodyGrid>
      </Container>
    </Section>

    <!-- Closing Statement -->
    <Section>
      <Container>
        <div style="text-align: center; max-width: 900px; margin: 0 auto; padding: var(--space-12) var(--space-6); background: linear-gradient(270deg, var(--color-bg) 0%, var(--color-bg-alt) 100%); border-radius: var(--border-radius-2xl); color: white; box-shadow: var(--shadow-xl);">
          <i class="fas fa-quote-left" style="font-size: 3rem; opacity: 0.2; margin-bottom: var(--space-4);"></i>
          <h2 style="font-size: var(--font-size-2xl); line-height: 1.4; font-weight: 500;">
            Te ofrecemos una <strong>solución integral</strong> para tu presencia de marca, con una producción profesional y con la experiencia necesaria para optimizar efectividad, tiempo y recursos.
          </h2>
          <div style="margin-top: var(--space-8);" class="btn">
            <a href={`${import.meta.env.BASE_URL}contacto`} style="display: inline-block; padding: var(--space-4) var(--space-10); text-decoration: none; border-radius: var(--border-radius-full); font-weight: 700; transition: all 0.3s ease;">
              Contáctanos hoy
            </a>
          </div>
        </div>
      </Container>
    </Section>
  </main>

  <FooterThreeCols slot="footer" />
</MainLayout>

<style>
  .service-category-card:hover {
    transform: translateY(-8px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-lg);
  }
  .btn {
    display: flex;
    justify-content: center;
    align-items: center;
    transition: all 0.3s ease;
  }

  .btn > a{
    background: var(--color-primary);
    color: white;
  }
  
  .btn:hover > a{
    background: white;
    color: var(--color-primary);
    border-color: var(--color-primary);
    transform: translateY(-4px);
  }
</style>
