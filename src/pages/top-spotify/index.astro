---
import MainLayout from "@layouts/MainLayout.astro";
import HeaderSticky from "@components/headers/HeaderSticky.astro";
import FooterThreeCols from "@components/footers/FooterThreeCols.astro";
import Section from "@components/base/Section.astro";
import Container from "@components/base/Container.astro";
import BodyGrid from "@components/body/BodyGrid.astro";
import LogoCard from "@components/logo/LogoCard.astro";

const cards = [
  {
    id:1,
    title: "Top 50 Artistas Venezolanos",
    image: "/img/guias/placeholder-guide.png",
    href: "top-spotify/top-50-artistas-venezolanos",
    description: "Ranking de los artistas venezolanos más escuchados en Spotify."
  },
  {
    id:2,
    title: "Top 50 Canciones Globales",
    image: "/img/guias/placeholder-guide.png",
    href: "top-spotify/top-50-canciones-globales",
    description: "Los hits más populares en todo el mundo hoy mismo."
  },
]

const base = import.meta.env.BASE_URL;
---

<MainLayout title="Biografías y Perfiles">
  <HeaderSticky slot="header" />

  <main>
    <Section>
      <Container>
        <div class="bio-intro">
          <h1>Lo que se escucha en Spotify</h1>
          <p>Conoce los artistas más escuchados en Spotify.</p>
        </div>

        <BodyGrid columns={cards.length > 3 ? 3 : cards.length}>
            {cards.map(card => (
              <a href={`${base}${card.href}`} class="event-card">
                <div class="image-wrapper">
                  <img src={card.image} alt={card.title} />
                </div>
                <div class="content">
                  <h3>{card.title}</h3>
                  <p class="description">{card.description?.substring(0, 100)}...</p>
                  <span class="btn-more">Más Información</span>
                </div>
              </a>
            ))}
          </BodyGrid>
      </Container>
    </Section>
  </main>

  <FooterThreeCols slot="footer" />
</MainLayout>

<style>
  .event-card {
    background: var(--color-bg);
    border-radius: var(--border-radius-xl);
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--color-border);
    transition: all 0.3s ease;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .event-card:hover {
    transform: translateY(-10px);
    border-color: var(--color-primary);
    box-shadow: var(--shadow-xl);
  }
  .image-wrapper {
    position: relative;
    height: 200px;
    overflow: hidden;
  }
  .image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .event-card:hover .image-wrapper img {
    transform: scale(1.1);
  }
  .date-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--color-primary);
    color: white;
    padding: 0.4rem 0.8rem;
    border-radius: var(--border-radius-md);
    font-size: 0.8rem;
    font-weight: 700;
  }
  .content {
    padding: 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }
  .content h3 {
    font-size: 1.4rem;
    margin-bottom: 0.5rem;
  }
  .location {
    font-size: 0.9rem;
    color: var(--color-primary-light);
    margin-bottom: 1rem;
  }
  .description {
    font-size: 0.9rem;
    color: var(--color-text-light);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }
  .btn-more {
    margin-top: auto;
    color: var(--color-primary);
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 1px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .btn-more::after {
    content: "→";
    transition: transform 0.3s ease;
  }
  .event-card:hover .btn-more::after {
    transform: translateX(5px);
  }
</style>
